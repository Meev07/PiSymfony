{% extends 'app_layout.html.twig' %}

{% block title %}Redeem Digital Cheque | ESPRIT WALLET{% endblock %}

{% block content %}
<div class="max-w-2xl mx-auto py-12">
    <div class="bg-white rounded-3xl p-10 border card-shadow">
        <div class="flex items-center gap-4 mb-8">
            <div class="w-16 h-16 rounded-2xl bg-primary/10 flex items-center justify-center">
                <i class="fa-solid fa-money-bill-transfer text-primary text-2xl"></i>
            </div>
            <div>
                <h1 class="text-3xl font-extrabold text-slate-800 tracking-tight">Redeem Cheque</h1>
                <p class="text-slate-500 font-medium">Verify security token to claim funds.</p>
            </div>
        </div>

        <form method="post" class="space-y-6">
            <div class="p-6 bg-slate-50 border rounded-2xl space-y-4">
                <label class="block text-xs uppercase font-black text-slate-400 tracking-widest pl-3">Cheque Serial Number</label>
                <div class="relative">
                    <i class="fa-solid fa-barcode absolute left-5 top-5 text-slate-300"></i>
                    <input type="text" name="serial" placeholder="EW-XXXXXX" required
                           class="w-full pl-14 pr-6 py-4 bg-white border border-slate-200 rounded-xl focus:ring-4 focus:ring-primary/10 focus:border-primary transition-all font-mono">
                </div>
            </div>

            <div class="p-6 bg-slate-50 border rounded-2xl space-y-4">
                <label class="block text-xs uppercase font-black text-slate-400 tracking-widest pl-3">Private Security Token</label>
                <div class="relative">
                    <i class="fa-solid fa-key absolute left-5 top-5 text-slate-300"></i>
                    <input type="text" name="token" placeholder="Enter private 32-char token" required
                           class="w-full pl-14 pr-6 py-4 bg-white border border-slate-200 rounded-xl focus:ring-4 focus:ring-primary/10 focus:border-primary transition-all font-mono">
                </div>
            </div>

            <div class="flex items-center gap-4 pt-4">
                <button type="submit" class="flex-1 bg-primary text-white font-black py-4 rounded-xl card-shadow hover:bg-primary-dark transition-all flex items-center justify-center gap-3">
                    <i class="fa-solid fa-check-double"></i>
                    Verify and Redeem Funds
                </button>
                <a href="{{ path('app_cheque_index') }}" class="px-8 py-4 bg-slate-100 text-slate-600 font-black rounded-xl hover:bg-slate-200 transition-all">
                    Cancel
                </a>
            </div>
        </form>

        <div class="mt-8 p-6 bg-blue-50 border border-blue-100 rounded-2xl flex gap-4">
            <i class="fa-solid fa-circle-info text-blue-400 mt-1"></i>
            <p class="text-sm text-blue-700 leading-relaxed font-medium">
                Redeming a digital cheque is instantaneous. The funds will be transferred from the sender's account to your primary wallet immediately after token verification.
            </p>
        </div>
    </div>
</div>
{% endblock %}
