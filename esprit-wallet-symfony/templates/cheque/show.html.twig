{% extends 'app_layout.html.twig' %}

{% block title %}Digital Cheque Details | ESPRIT WALLET{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto py-12">
    <!-- Success Badge -->
    <div class="mb-10 text-center">
        <div class="inline-flex items-center gap-3 px-6 py-3 bg-emerald-50 text-emerald-600 rounded-full border border-emerald-100 font-black uppercase tracking-widest text-xs animate-bounce">
            <i class="fa-solid fa-circle-check text-lg"></i>
            Blockchain Verification Successful
        </div>
    </div>

    <!-- Main Certificate Card -->
    <div class="bg-white rounded-[2.5rem] p-1 border card-shadow overflow-hidden relative">
        <!-- Security Header Gradient -->
        <div class="h-4 gradient-bg"></div>
        
        <div class="p-10 pt-12">
            <div class="flex flex-col md:flex-row justify-between items-start gap-8 mb-12 border-b pb-12 border-slate-100">
                <div class="flex items-center gap-6">
                    <div class="w-20 h-20 rounded-3xl bg-slate-900 flex items-center justify-center text-white text-4xl shadow-2xl">
                        <i class="fa-solid fa-shield-halved"></i>
                    </div>
                    <div>
                        <h1 class="text-3xl font-black text-slate-800 uppercase tracking-tight">Security Certificate</h1>
                        <p class="text-slate-400 font-bold uppercase tracking-widest text-[10px]">Reference: {{ cheque.chequeNumber }}</p>
                    </div>
                </div>
                <div class="text-right">
                    <p class="text-sm font-black text-slate-400 uppercase tracking-widest mb-1">Face Value</p>
                    <p class="text-5xl font-black text-slate-800">{{ cheque.amount }} <span class="text-2xl text-slate-400">TND</span></p>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                <!-- Left: Critical Credentials -->
                <div class="space-y-8">
                    <div class="p-8 bg-slate-900 rounded-3xl text-white relative overflow-hidden group">
                        <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition">
                            <i class="fa-solid fa-key text-6xl -rotate-12"></i>
                        </div>
                        <label class="block text-[10px] uppercase font-black text-slate-500 tracking-[0.2em] mb-4">Movable Security Token</label>
                        <div class="flex items-center justify-between gap-4">
                            <code id="secureToken" class="text-xl font-mono font-bold text-amber-400 break-all select-all">{{ cheque.secureToken }}</code>
                            <button onclick="copyToClipboard('{{ cheque.secureToken }}', this)" class="p-4 bg-white/10 hover:bg-white/20 rounded-2xl transition flex-shrink-0">
                                <i class="fa-solid fa-copy"></i>
                            </button>
                        </div>
                        <p class="mt-6 text-[10px] text-slate-400 font-bold uppercase leading-relaxed">
                            <i class="fa-solid fa-triangle-exclamation text-amber-500 mr-2"></i>
                            CRITICAL: Share this token ONLY with the intended recipient. It is required for funds redemption.
                        </p>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div class="p-6 bg-slate-50 rounded-2xl border border-slate-100">
                            <h4 class="text-[10px] font-black uppercase text-slate-400 tracking-widest mb-2">Issued To</h4>
                            <p class="font-bold text-slate-700">{{ cheque.receiverIban|default('Standard Bearer') }}</p>
                        </div>
                        <div class="p-6 bg-emerald-50 rounded-2xl border border-emerald-100">
                            <h4 class="text-[10px] font-black uppercase text-emerald-400 tracking-widest mb-2">Status</h4>
                            <p class="font-black text-emerald-600 uppercase italic">{{ cheque.status }}</p>
                        </div>
                    </div>
                </div>

                <!-- Right: Metadata & Timeline -->
                <div class="space-y-6">
                    <div class="space-y-4">
                        <h4 class="text-xs font-black uppercase text-slate-800 tracking-widest flex items-center gap-2">
                            <i class="fa-solid fa-circle-info text-primary"></i>
                            Issuance Details
                        </h4>
                        <div class="space-y-3">
                            <div class="flex justify-between py-3 border-b text-sm font-medium">
                                <span class="text-slate-400">Creation Date</span>
                                <span class="text-slate-700 font-bold">{{ cheque.createdAt|date('M d, Y - H:i') }}</span>
                            </div>
                            <div class="flex justify-between py-3 border-b text-sm font-medium">
                                <span class="text-slate-400">Expiration Date</span>
                                <span class="text-red-500 font-bold">{{ cheque.expirationDate|date('M d, Y - H:i') }}</span>
                            </div>
                            <div class="flex justify-between py-3 border-b text-sm font-medium">
                                <span class="text-slate-400">Issuer Wallet</span>
                                <span class="text-slate-700 font-bold">{{ app.user.firstName }} {{ app.user.lastName }}</span>
                            </div>
                        </div>
                    </div>

                    <div class="p-6 bg-amber-50 rounded-2xl border border-amber-100 flex items-start gap-4">
                        <i class="fa-solid fa-lightbulb text-amber-500 mt-1"></i>
                        <p class="text-xs text-amber-700 font-bold leading-relaxed">
                            The funds corresponding to this cheque have been temporarily locked in your wallet until the recipient completes the redemption process.
                        </p>
                    </div>
                </div>
            </div>

            <div class="mt-12 flex flex-col md:flex-row items-center justify-between gap-6 pt-10 border-t border-slate-100">
                <div class="flex items-center gap-4">
                    <a href="{{ path('app_cheque_index') }}" class="px-8 py-4 bg-slate-900 text-white rounded-2xl font-black uppercase tracking-widest hover:shadow-xl transition group">
                        <i class="fa-solid fa-arrow-left mr-2 group-hover:-translate-x-1 transition"></i> Back to Ledger
                    </a>
                    <a href="{{ path('app_cheque_receipt', {'id': cheque.id}) }}" target="_blank"
                       class="px-8 py-4 bg-slate-100 text-slate-600 rounded-2xl font-black uppercase tracking-widest hover:bg-slate-200 hover:text-slate-800 transition inline-flex items-center gap-2">
                        <i class="fa-solid fa-print"></i> Print Receipt
                    </a>
                </div>
                
                {% if cheque.status == 'PENDING' %}
                <form method="post" action="{{ path('app_cheque_delete', {'id': cheque.id}) }}" onsubmit="return confirm('WARNING: Cancelling this cheque will return funds to your wallet. Proceed?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ cheque.id) }}">
                    <button class="text-red-400 font-black uppercase tracking-widest text-[10px] hover:text-red-600 transition flex items-center gap-2">
                        <i class="fa-solid fa-trash-can"></i>
                        Cancel Issuance
                    </button>
                </form>
                {% endif %}
            </div>
        </div>
    </div>
</div>

{# ═══════════════════════════════════════════════════════════
   PRINT RECEIPT — only visible during window.print()
   ═══════════════════════════════════════════════════════════ #}
<div id="printReceipt" style="display:none;">

  <div class="receipt-wrap">

    {# Top gradient bar #}
    <div class="receipt-gradient-bar"></div>

    {# Header #}
    <div class="receipt-header">
      <div class="receipt-logo-wrap">
        <div class="receipt-logo">🛡</div>
        <div>
          <div class="receipt-brand">ESPRIT WALLET</div>
          <div class="receipt-brand-sub">Secure Digital Finance</div>
        </div>
      </div>
      <div class="receipt-meta">
        <div class="receipt-date-label">PRINTED</div>
        <div class="receipt-date-val" id="printDate"></div>
      </div>
    </div>

    {# Title banner #}
    <div class="receipt-title-banner">
      <div class="receipt-title-text">SECURITY CERTIFICATE</div>
      <div class="receipt-title-sub">Official Digital Cheque Receipt</div>
    </div>

    {# Amount hero #}
    <div class="receipt-amount-hero">
      <div class="receipt-amount-label">FACE VALUE</div>
      <div class="receipt-amount-val">{{ cheque.amount|number_format(2, '.', ',') }} <span class="receipt-currency">TND</span></div>
    </div>

    {# Two-column details #}
    <div class="receipt-details-grid">
      <div class="receipt-detail-item">
        <div class="receipt-detail-label">Reference Number</div>
        <div class="receipt-detail-val">{{ cheque.chequeNumber }}</div>
      </div>
      <div class="receipt-detail-item">
        <div class="receipt-detail-label">Status</div>
        <div class="receipt-detail-val receipt-status">{{ cheque.status }}</div>
      </div>
      <div class="receipt-detail-item">
        <div class="receipt-detail-label">Issuer</div>
        <div class="receipt-detail-val">{{ app.user.firstName }} {{ app.user.lastName }}</div>
      </div>
      <div class="receipt-detail-item">
        <div class="receipt-detail-label">Issued To</div>
        <div class="receipt-detail-val">{{ cheque.receiverIban|default('Standard Bearer') }}</div>
      </div>
      <div class="receipt-detail-item">
        <div class="receipt-detail-label">Creation Date</div>
        <div class="receipt-detail-val">{{ cheque.createdAt|date('d/m/Y  H:i') }}</div>
      </div>
      <div class="receipt-detail-item">
        <div class="receipt-detail-label">Expiration Date</div>
        <div class="receipt-detail-val receipt-expiry">{{ cheque.expirationDate|date('d/m/Y  H:i') }}</div>
      </div>
    </div>

    {# Security token box #}
    <div class="receipt-token-section">
      <div class="receipt-token-title">🔑 MOVABLE SECURITY TOKEN</div>
      <div class="receipt-token-val">{{ cheque.secureToken }}</div>
      <div class="receipt-token-warn">⚠ CONFIDENTIAL — Share exclusively with the intended recipient. Required for fund redemption.</div>
    </div>

    {# Notice #}
    <div class="receipt-notice">
      <strong>📌 Important:</strong> The funds of <strong>{{ cheque.amount|number_format(2, '.', ',') }} TND</strong> are locked in your wallet until the recipient completes the redemption process using the security token above.
    </div>

    {# Footer #}
    <div class="receipt-footer">
      <div class="receipt-footer-line"></div>
      <div class="receipt-footer-text">
        ESPRIT WALLET ∙ Secure Digital Finance Platform ∙ V1.0-STABLE
      </div>
      <div class="receipt-footer-sub">This document is computer-generated and constitutes an official receipt.</div>
    </div>

  </div><!-- .receipt-wrap -->

</div><!-- #printReceipt -->

<style>
/* ── Print-only styles ──────────────────────────────────── */
@media print {
  body > *:not(#printReceipt) { display: none !important; }
  #printReceipt { display: block !important; }

  @page {
    size: A4;
    margin: 10mm 15mm;
  }

  /* reset */
  body { background: #fff !important; }
}

/* ── Receipt component styles (used on screen-print) ──── */
.receipt-wrap {
  font-family: 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
  background: #ffffff;
  width: 100%;
  max-width: 700px;
  margin: 0 auto;
  color: #1e293b;
}

.receipt-gradient-bar {
  height: 10px;
  background: linear-gradient(90deg, #0ea5e9 0%, #6366f1 50%, #8b5cf6 100%);
  border-radius: 6px 6px 0 0;
}

.receipt-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20px 28px 16px;
  border-bottom: 1px solid #e2e8f0;
}

.receipt-logo-wrap {
  display: flex;
  align-items: center;
  gap: 12px;
}

.receipt-logo {
  font-size: 28px;
  background: #0f172a;
  color: #fff;
  width: 46px;
  height: 46px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.receipt-brand {
  font-size: 15px;
  font-weight: 900;
  letter-spacing: 0.12em;
  color: #0f172a;
}

.receipt-brand-sub {
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.15em;
  color: #94a3b8;
  text-transform: uppercase;
  margin-top: 2px;
}

.receipt-meta {
  text-align: right;
}

.receipt-date-label {
  font-size: 8px;
  font-weight: 800;
  letter-spacing: 0.2em;
  color: #94a3b8;
  text-transform: uppercase;
}

.receipt-date-val {
  font-size: 11px;
  font-weight: 700;
  color: #475569;
  margin-top: 2px;
}

.receipt-title-banner {
  background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
  color: #fff;
  padding: 22px 28px;
  text-align: center;
}

.receipt-title-text {
  font-size: 20px;
  font-weight: 900;
  letter-spacing: 0.18em;
  text-transform: uppercase;
}

.receipt-title-sub {
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.2em;
  color: #94a3b8;
  text-transform: uppercase;
  margin-top: 4px;
}

.receipt-amount-hero {
  background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
  border: 2px dashed #bae6fd;
  margin: 20px 28px;
  border-radius: 14px;
  padding: 20px 24px;
  text-align: center;
}

.receipt-amount-label {
  font-size: 9px;
  font-weight: 800;
  letter-spacing: 0.25em;
  color: #0ea5e9;
  text-transform: uppercase;
  margin-bottom: 4px;
}

.receipt-amount-val {
  font-size: 42px;
  font-weight: 900;
  color: #0f172a;
  line-height: 1;
}

.receipt-currency {
  font-size: 20px;
  color: #64748b;
  font-weight: 700;
}

.receipt-details-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  margin: 0 28px;
  border: 1px solid #e2e8f0;
  border-radius: 12px;
  overflow: hidden;
}

.receipt-detail-item {
  padding: 12px 16px;
  border-bottom: 1px solid #f1f5f9;
  border-right: 1px solid #f1f5f9;
}

.receipt-detail-item:nth-child(even) { border-right: none; }
.receipt-detail-item:nth-last-child(-n+2) { border-bottom: none; }

.receipt-detail-label {
  font-size: 8px;
  font-weight: 800;
  letter-spacing: 0.15em;
  color: #94a3b8;
  text-transform: uppercase;
  margin-bottom: 3px;
}

.receipt-detail-val {
  font-size: 12px;
  font-weight: 700;
  color: #1e293b;
}

.receipt-status { color: #10b981; text-transform: uppercase; }
.receipt-expiry  { color: #ef4444; }

.receipt-token-section {
  margin: 20px 28px;
  background: #0f172a;
  color: #fff;
  border-radius: 14px;
  padding: 18px 20px;
}

.receipt-token-title {
  font-size: 9px;
  font-weight: 800;
  letter-spacing: 0.2em;
  color: #64748b;
  text-transform: uppercase;
  margin-bottom: 10px;
}

.receipt-token-val {
  font-family: 'Courier New', monospace;
  font-size: 14px;
  font-weight: 700;
  color: #fbbf24;
  word-break: break-all;
  letter-spacing: 0.05em;
  line-height: 1.5;
  margin-bottom: 12px;
}

.receipt-token-warn {
  font-size: 8.5px;
  font-weight: 600;
  color: #94a3b8;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  line-height: 1.5;
}

.receipt-notice {
  margin: 0 28px 20px;
  background: #fffbeb;
  border: 1px solid #fde68a;
  border-radius: 10px;
  padding: 12px 16px;
  font-size: 11px;
  color: #78350f;
  line-height: 1.6;
}

.receipt-footer {
  padding: 0 28px 24px;
  text-align: center;
}

.receipt-footer-line {
  border-top: 2px dashed #e2e8f0;
  margin-bottom: 14px;
}

.receipt-footer-text {
  font-size: 9px;
  font-weight: 800;
  letter-spacing: 0.18em;
  color: #94a3b8;
  text-transform: uppercase;
}

.receipt-footer-sub {
  font-size: 8px;
  color: #cbd5e1;
  margin-top: 4px;
  font-style: italic;
}
</style>

<script>
function copyToClipboard(text, btn) {
    navigator.clipboard.writeText(text).then(() => {
        const icon = btn.querySelector('i');
        icon.classList.remove('fa-copy');
        icon.classList.add('fa-check');
        btn.classList.replace('bg-white/10', 'bg-emerald-500/20');
        btn.classList.add('text-emerald-400');
        
        setTimeout(() => {
            icon.classList.remove('fa-check');
            icon.classList.add('fa-copy');
            btn.classList.replace('bg-emerald-500/20', 'bg-white/10');
            btn.classList.remove('text-emerald-400');
        }, 2000);
    });
}

function printReceipt() {
    // Stamp the print date inside the hidden receipt div
    const now = new Date();
    const formatted = now.toLocaleDateString('en-GB', {
        day: '2-digit', month: 'short', year: 'numeric'
    }) + '  ' + now.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
    document.getElementById('printDate').textContent = formatted;

    // Grab the receipt HTML and all inline styles from this page's <style> block
    const receiptHTML = document.getElementById('printReceipt').innerHTML;
    const styleContent = Array.from(document.querySelectorAll('style'))
        .map(s => s.innerHTML).join('\n');

    // Open a dedicated print window
    const win = window.open('', '_blank', 'width=800,height=900');
    win.document.write(`
        <!DOCTYPE html>
        <html lang="en">
        <head>
            <meta charset="UTF-8">
            <title>Receipt — {{ cheque.chequeNumber }}</title>
            <style>
                * { margin: 0; padding: 0; box-sizing: border-box; }
                body { background: #fff; }
                ${styleContent}
                @media print {
                    @page { size: A4; margin: 10mm 15mm; }
                    body { background: #fff !important; }
                }
            </style>
        </head>
        <body>${receiptHTML}</body>
        </html>
    `);
    win.document.close();
    win.focus();
    // Small delay for fonts/styles to render, then print
    setTimeout(() => { win.print(); win.close(); }, 400);
}
</script>
{% endblock %}
