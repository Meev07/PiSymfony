{{ form_start(form, {'action': path('app_cheque_new'), 'attr': {'data-turbo': 'false', 'novalidate': 'novalidate', 'id': 'cheque_creation_form'}}) }}
<script>
    console.log("Form initialized with action: {{ path('app_cheque_new') }}");
    document.addEventListener('submit', function(e) {
        if (e.target.id === 'cheque_creation_form') {
            console.log("Submit event intercepted for #cheque_creation_form");
        }
    });
</script>
    <div class="space-y-8">
        <!-- Serial Number (Readonly) -->
        <div class="p-6 bg-slate-50 border rounded-3xl space-y-4 opacity-70">
            <label class="block text-[10px] uppercase font-black text-slate-400 tracking-widest pl-3">Digital Reference (Auto-Generated)</label>
            {{ form_widget(form.chequeNumber, {'attr': {'class': 'w-full bg-white border-none outline-none p-4 rounded-2xl font-mono text-lg text-slate-400 shadow-sm'}}) }}
        </div>

        <!-- Amount -->
        <div class="p-8 bg-white border-2 {{ form_errors(form.amount) ? 'border-red-200' : 'border-slate-100 shadow-sm' }} rounded-[2rem] space-y-4 transition-all focus-within:border-primary">
            <div class="flex items-center justify-between">
                <label class="block text-[10px] uppercase font-black text-slate-400 tracking-widest pl-3">Amount (TND) <span class="text-red-500">*</span></label>
                {% if form_errors(form.amount) %}
                    <span class="text-[10px] font-black text-red-500 uppercase tracking-widest">
                        <i class="fa-solid fa-triangle-exclamation mr-1"></i> Invalid Amount
                    </span>
                {% endif %}
            </div>
            <div class="relative">
                <span class="absolute left-6 top-1/2 -translate-y-1/2 text-2xl font-black text-slate-300 pointer-events-none">TND</span>
                {{ form_widget(form.amount, {
                    'attr': {
                        'class': 'w-full bg-slate-50/50 border-none outline-none py-6 pl-20 pr-8 rounded-2xl font-black text-4xl text-slate-800 transition',
                        'oninput': "this.value = this.value.replace(/[^0-9.]/g, '').replace(/(\\..*?)\\..*/g, '$1');",
                        'autocomplete': 'off'
                    }
                }) }}
            </div>
            {{ form_errors(form.amount) }}
            <p class="text-[10px] text-slate-400 font-bold uppercase tracking-tight pl-3">Funds will be held until redemption</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- Receiver -->
            <div class="p-6 bg-white border-2 {{ form_errors(form.receiverIban) ? 'border-red-200' : 'border-slate-100 shadow-sm' }} rounded-3xl space-y-4 transition-all focus-within:border-primary">
                <div class="flex items-center justify-between">
                    <label class="block text-[10px] uppercase font-black text-slate-400 tracking-widest pl-3">Recipient IBAN (Optional)</label>
                    {% if form_errors(form.receiverIban) %}
                        <span class="text-[10px] font-black text-red-500 uppercase tracking-widest">Format Error</span>
                    {% endif %}
                </div>
                {{ form_widget(form.receiverIban, {'attr': {'class': 'w-full bg-slate-50/50 border-none outline-none p-5 rounded-2xl font-bold font-mono text-slate-700'}}) }}
                {{ form_errors(form.receiverIban) }}
            </div>

            <!-- Expiration -->
            <div class="p-6 bg-white border-2 {{ form_errors(form.expirationDate) ? 'border-red-200' : 'border-slate-100 shadow-sm' }} rounded-3xl space-y-4 transition-all focus-within:border-primary">
                <div class="flex items-center justify-between">
                    <label class="block text-[10px] uppercase font-black text-slate-400 tracking-widest pl-3">Validity Expiration <span class="text-red-500">*</span></label>
                    {% if form_errors(form.expirationDate) %}
                        <span class="text-[10px] font-black text-red-500 uppercase tracking-widest">Date Required</span>
                    {% endif %}
                </div>
                {{ form_widget(form.expirationDate, {'attr': {'class': 'w-full bg-slate-50/50 border-none outline-none p-5 rounded-2xl font-bold text-slate-700'}}) }}
                {{ form_errors(form.expirationDate) }}
            </div>
        </div>

        <div class="flex flex-col md:flex-row items-center gap-6 pt-10">
            <button type="submit" class="w-full md:flex-1 gradient-bg text-white py-5 rounded-2xl font-black uppercase tracking-widest hover:shadow-2xl hover:scale-[1.02] active:scale-95 transition-all shadow-xl shadow-primary/20">
                <i class="fa-solid fa-stamp mr-2 text-xl pointer-events-none"></i> {{ button_label|default('Issue Security Cheque') }}
            </button>
            <a href="{{ path('app_cheque_index') }}" class="w-full md:w-auto px-12 py-5 bg-slate-100 text-slate-400 hover:bg-slate-200 hover:text-slate-600 rounded-2xl font-black uppercase tracking-widest transition text-center">
                Cancel
            </a>
        </div>
    </div>
{{ form_end(form) }}
