{% extends 'app_layout.html.twig' %}

{% block title %}Dashboard | ESPRIT WALLET{% endblock %}

{% block content %}
    <div class="space-y-8">
        <!-- Dashboard Header -->
        <div class="flex items-center justify-between">
            <h1 class="text-3xl font-extrabold text-slate-800 tracking-tight">Overview</h1>
            <div class="bg-white px-4 py-2 rounded-xl border flex items-center gap-2 text-slate-500 font-medium">
                <i class="fa-solid fa-calendar text-primary"></i>
                {{ "now"|date('F d, Y') }}
            </div>
        </div>

        <!-- Balance Card -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="col-span-1 md:col-span-2 gradient-bg rounded-3xl p-8 text-white relative overflow-hidden card-shadow">
                <div class="relative z-10">
                    <p class="text-white/70 font-medium mb-1">Total Available Balance</p>
                    <h2 class="text-5xl font-black mb-12">{{ totalBalance }} TND</h2>
                    <div class="flex items-center gap-4">
                        <a href="{{ path('app_account_new') }}" class="bg-white/20 hover:bg-white/30 px-6 py-3 rounded-2xl font-bold transition">
                            <i class="fa-solid fa-plus mr-2"></i> Add Account
                        </a>
                        <a href="{{ path('app_cheque_new') }}" class="bg-white text-primary px-6 py-3 rounded-2xl font-bold hover:bg-slate-100 transition whitespace-nowrap">
                            <i class="fa-solid fa-paper-plane mr-2"></i> Create Cheque
                        </a>
                    </div>
                </div>
                <!-- Background Decoration -->
                <div class="absolute -right-20 -bottom-20 w-64 h-64 bg-white/10 rounded-full blur-3xl"></div>
                <div class="absolute right-10 top-10 w-32 h-32 bg-white/5 rounded-full blur-2xl"></div>
            </div>
            
            <!-- Account Summary Card -->
            <div class="bg-white rounded-3xl p-6 border card-shadow">
                <h3 class="font-bold text-slate-700 mb-4 border-b pb-3">My Linked Accounts</h3>
                <div class="space-y-4">
                    {% for account in accounts %}
                        <div class="flex items-center justify-between group cursor-pointer hover:bg-slate-50 p-2 rounded-xl transition">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-slate-400 group-hover:bg-primary/10 group-hover:text-primary transition">
                                    <i class="fa-solid fa-bank"></i>
                                </div>
                                <div>
                                    <p class="text-sm font-bold text-slate-700">{{ account.type }}</p>
                                    <p class="text-xs text-slate-400 font-mono">{{ account.accountNumber|slice(-4) }} ****</p>
                                </div>
                            </div>
                            <span class="font-bold text-slate-800">{{ account.balance }} TND</span>
                        </div>
                    {% else %}
                        <div class="text-center py-6">
                            <div class="text-slate-300 text-3xl mb-2"><i class="fa-solid fa-folder-open"></i></div>
                            <p class="text-xs text-slate-400">No accounts registered yet.</p>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>

        <!-- Transactions and Cheques Row -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <!-- Recent Transactions Table -->
            <div class="bg-white rounded-3xl p-6 border card-shadow">
                <div class="flex items-center justify-between mb-6 pb-2 border-b">
                    <h3 class="font-bold text-slate-800">Recent Transactions</h3>
                    <a href="#" class="text-xs font-bold text-primary hover:underline">View All History</a>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left text-sm">
                        <thead>
                            <tr class="text-slate-400 border-b">
                                <th class="pb-3 px-4 font-medium uppercase text-[10px] tracking-widest">Description</th>
                                <th class="pb-3 font-medium uppercase text-[10px] tracking-widest text-center">Date</th>
                                <th class="pb-3 text-right font-medium uppercase text-[10px] tracking-widest">Amount</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y">
                            {% for transaction in recentTransactions %}
                                <tr class="hover:bg-slate-50 transition">
                                    <td class="py-4 px-4">
                                        <div class="flex items-center gap-3">
                                            <span class="w-8 h-8 rounded-lg {{ transaction.type == 'DEBIT' ? 'bg-red-50 text-red-500' : 'bg-emerald-50 text-emerald-500' }} flex items-center justify-center text-xs">
                                                <i class="fa-solid {{ transaction.type == 'DEBIT' ? 'fa-arrow-up-long' : 'fa-arrow-down-long' }}"></i>
                                            </span>
                                            <div>
                                                <p class="font-bold text-slate-700">{{ transaction.receiver.firstName }} {{ transaction.receiver.lastName }}</p>
                                                <p class="text-[10px] text-slate-400 font-bold uppercase tracking-tighter">{{ transaction.type }}</p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="py-4 text-center text-slate-500">{{ transaction.createdAt|date('M d') }}</td>
                                    <td class="py-4 text-right font-bold {{ transaction.type == 'DEBIT' ? 'text-red-500' : 'text-emerald-500' }}">
                                        {{ transaction.type == 'DEBIT' ? '-' : '+' }}{{ transaction.amount }} TND
                                    </td>
                            {% else %}
                                <tr><td colspan="3" class="text-center py-10 text-slate-300 italic">No recent transactions found.</td></tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Digital Cheques Overview -->
            <div class="bg-white rounded-3xl p-6 border card-shadow">
                <div class="flex items-center justify-between mb-6 pb-2 border-b">
                    <h3 class="font-bold text-slate-800">Pending Digital Cheques</h3>
                    <a href="{{ path('app_cheque_index') }}" class="text-xs font-bold text-primary hover:underline">Manage Cheques</a>
                </div>
                <div class="space-y-4">
                    {% for cheque in recentCheques %}
                        <div class="p-4 rounded-2xl border bg-slate-50 flex items-center justify-between">
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 rounded-xl bg-white border flex items-center justify-center text-primary text-xl shadow-sm">
                                    <i class="fa-solid fa-money-bill-transfer"></i>
                                </div>
                                <div class="overflow-hidden">
                                    <p class="font-bold text-slate-700 text-sm whitespace-nowrap overflow-ellipsis">{{ cheque.chequeNumber }}</p>
                                    <p class="text-[10px] font-bold text-slate-400 uppercase">Receiver: {{ cheque.receiverIban|default('N/A') }}</p>
                                </div>
                            </div>
                            <div class="text-right">
                                <p class="font-black text-slate-800">{{ cheque.amount }} TND</p>
                                <span class="px-2 py-0.5 rounded-full text-[9px] font-bold uppercase tracking-tight
                                    {{ cheque.status == 'PENDING' ? 'bg-amber-100 text-amber-700' : 
                                       cheque.status == 'CONFIRMED' ? 'bg-emerald-100 text-emerald-700' : 
                                       cheque.status == 'CANCELLED' ? 'bg-red-100 text-red-700' : 'bg-slate-100 text-slate-700' }}">
                                    {{ cheque.status }}
                                </span>
                            </div>
                        </div>
                    {% else %}
                        <div class="text-center py-10">
                            <div class="text-slate-200 text-5xl mb-4"><i class="fa-solid fa-stamp"></i></div>
                            <p class="text-sm text-slate-400">Your digital chequebook is currently inactive.</p>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>

        <!-- Quick Action Grid -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 pb-8">
            <a href="{{ path('app_account_new') }}" class="bg-white p-6 rounded-3xl border border-slate-200 text-center hover:bg-primary hover:text-white transition group card-shadow">
                <i class="fa-solid fa-plus-circle text-2xl text-primary group-hover:text-white mb-3 flex justify-center"></i>
                <p class="font-bold text-sm">Add Account</p>
            </a>
            <a href="{{ path('app_cheque_new') }}" class="bg-white p-6 rounded-3xl border border-slate-200 text-center hover:bg-primary hover:text-white transition group card-shadow">
                <i class="fa-solid fa-file-invoice-dollar text-2xl text-primary group-hover:text-white mb-3 flex justify-center"></i>
                <p class="font-bold text-sm">New Cheque</p>
            </a>
            <a href="{{ path('app_cheque_scan') }}" class="bg-white p-6 rounded-3xl border border-slate-200 text-center hover:bg-primary hover:text-white transition group card-shadow">
                <i class="fa-solid fa-expand text-2xl text-primary group-hover:text-white mb-3 flex justify-center"></i>
                <p class="font-bold text-sm">Scan QR/OCR</p>
            </a>
            <a href="{{ path('app_complaint_new') }}" class="bg-white p-6 rounded-3xl border border-slate-200 text-center hover:bg-primary hover:text-white transition group card-shadow">
                <i class="fa-solid fa-headset text-2xl text-primary group-hover:text-white mb-3 flex justify-center"></i>
                <p class="font-bold text-sm">Support Hub</p>
            </a>
        </div>
    </div>
{% endblock %}
