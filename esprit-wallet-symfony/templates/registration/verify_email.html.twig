{% extends 'base.html.twig' %}

{% block title %}Verify Your Account - Esprit Wallet{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center bg-slate-50 p-6">
    <div class="w-full max-w-md animate-in fade-in slide-in-from-bottom-4 duration-700">
        <!-- Logo/Header -->
        <div class="text-center mb-10">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-primary rounded-2xl shadow-xl shadow-primary/20 mb-6">
                <i class="fa-solid fa-envelope-circle-check text-white text-3xl"></i>
            </div>
            <h1 class="text-3xl font-black text-slate-900 tracking-tight">Verify Your Email</h1>
            <p class="text-slate-500 mt-2">We sent a 6-digit code to <span class="font-bold text-slate-800">{{ email }}</span></p>
        </div>

        <!-- Verification Form -->
        <div class="bg-white rounded-[32px] shadow-2xl shadow-slate-200/50 p-8 border border-slate-100">
            <form method="post" class="space-y-8">
                <div class="space-y-4">
                    <label for="code" class="text-[10px] uppercase font-black text-slate-400 tracking-[0.2em] ml-1">Verification Code</label>
                    <div class="relative">
                        <input type="text" name="code" id="code" maxlength="6" autofocus
                               class="w-full px-6 py-5 bg-slate-50 border-2 border-slate-100 rounded-2xl text-center text-3xl font-black tracking-[0.5em] text-primary focus:border-primary focus:bg-white outline-none transition-all"
                               placeholder="000000" required>
                    </div>
                </div>

                <button type="submit" class="w-full py-5 bg-slate-900 text-white rounded-2xl font-black uppercase tracking-widest text-[11px] hover:bg-slate-800 transition-all shadow-xl shadow-slate-200 active:scale-[0.98]">
                    Confirm Account
                </button>
            </form>

            <div class="mt-10 pt-8 border-t border-slate-50 text-center">
                <p class="text-sm text-slate-500">Didn't receive the code?</p>
                <a href="#" class="text-sm font-bold text-primary hover:underline mt-1 inline-block">Resend Code</a>
            </div>
        </div>

        <div class="text-center mt-8">
            <a href="{{ path('app_login') }}" class="text-sm font-bold text-slate-400 hover:text-slate-600 transition-colors">
                <i class="fa-solid fa-arrow-left mr-2"></i> Back to Login
            </a>
        </div>
    </div>
</div>

<script>
    // Autofocus and formatting
    const input = document.getElementById('code');
    input.addEventListener('input', (e) => {
        e.target.value = e.target.value.replace(/[^0-9]/g, '');
    });
</script>
{% endblock %}
