{% extends 'base.html.twig' %}

{% block body %}
    <!-- Sidebar -->
    <aside class="w-64 gradient-bg text-white flex flex-col fixed inset-y-0 left-0 z-50">
        <div class="p-6 text-2xl font-bold border-b border-white/10 uppercase tracking-wider flex items-center gap-3">
            <i class="fa-solid fa-wallet"></i>
            Esprit Wallet
        </div>
        <nav class="flex-1 mt-6 px-4 space-y-2" data-turbo="true">
            {% set active_route = app.request.get('_route') %}
            
            <a href="{{ path('user_dashboard') }}" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/10 transition {{ active_route == 'user_dashboard' ? 'bg-white/20 shadow-lg' : '' }}">
                <i class="fa-solid fa-house w-5 text-sky-200"></i>
                Dashboard
            </a>
            <a href="{{ path('app_account_index') }}" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/10 transition {{ 'account' in active_route ? 'bg-white/20' : '' }}">
                <i class="fa-solid fa-credit-card w-5 text-sky-200"></i>
                Accounts
            </a>
            <a href="{{ path('app_cheque_index') }}" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/10 transition {{ 'cheque' in active_route and 'scan' not in active_route ? 'bg-white/20' : '' }}">
                <i class="fa-solid fa-money-check w-5 text-sky-200"></i>
                Digital Cheques
            </a>
            <a href="{{ path('app_cheque_scan') }}" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/10 transition {{ 'scan' in active_route ? 'bg-white/20' : '' }}">
                <i class="fa-solid fa-qrcode w-5 text-sky-200"></i>
                Scan Cheque
            </a>
            <a href="#" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/10 transition">
                <i class="fa-solid fa-arrow-right-arrow-left w-5 text-sky-200"></i>
                Transactions
            </a>
            <a href="{{ path('app_complaint_index') }}" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/10 transition {{ 'complaint' in active_route ? 'bg-white/20' : '' }}">
                <i class="fa-solid fa-circle-exclamation w-5 text-sky-200"></i>
                Complaints
            </a>
            {% if is_granted('ROLE_ADMIN') %}
                <div class="pt-6 border-t border-white/10 mt-6">
                    <p class="text-[10px] uppercase text-white/40 font-black px-4 mb-2 tracking-widest">Admin Panel</p>
                    <a href="{{ path('admin_dashboard') }}" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/10 transition border border-white/5 bg-white/5">
                        <i class="fa-solid fa-gauge-high w-5 text-pink-400"></i>
                        Go to Admin
                    </a>
                </div>
            {% endif %}
        </nav>
        <div class="p-4 border-t border-white/10 space-y-2">
            <a href="{{ path('app_profile_settings') }}" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/10 transition {{ app.request.get('_route') == 'app_profile_settings' ? 'bg-white/20' : '' }}">
                <i class="fa-solid fa-gear w-5 text-sky-200"></i>
                Settings
            </a>
            <a href="{{ path('app_logout') }}" data-turbo="false" class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-red-500/20 text-red-100 transition whitespace-nowrap">
                <i class="fa-solid fa-right-from-bracket w-5"></i>
                Logout
            </a>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 ml-64 flex flex-col h-full bg-slate-50">
        <!-- Top Bar -->
        <header class="h-16 bg-white border-b flex items-center justify-between px-8 z-10 sticky top-0">
            <div class="text-slate-500 font-medium">
                {% block breadcrumb %}
                    {% if app.user %}
                        Welcome, {{ app.user.firstName }}
                    {% else %}
                        Welcome
                    {% endif %}
                {% endblock %}
            </div>
            <div class="flex items-center gap-6">
                <!-- Notifications -->
                <div class="relative group cursor-pointer inline-block">
                    <button class="relative p-2 text-slate-400 hover:text-primary transition">
                        <i class="fa-solid fa-bell text-xl"></i>
                        <span class="absolute top-1 right-1 w-2 h-2 bg-red-500 rounded-full border-2 border-white"></span>
                    </button>
                    <!-- Notification Dropdown Placeholder -->
                    <div class="absolute right-0 mt-2 w-80 bg-white border rounded-xl shadow-xl hidden group-hover:block z-50">
                        <div class="p-4 border-b font-bold text-slate-700">Notifications</div>
                        <div class="max-h-96 overflow-y-auto">
                            <div class="p-4 text-sm text-slate-500 text-center italic">No new notifications</div>
                        </div>
                    </div>
                </div>

                <!-- Profile Dropdown -->
                {% if app.user %}
                    <div class="flex items-center gap-3 cursor-pointer group relative">
                        <div class="text-right hidden md:block">
                            <p class="text-sm font-bold text-slate-800">{{ app.user.firstName }} {{ app.user.lastName }}</p>
                            <p class="text-xs text-slate-500 uppercase font-bold">{{ is_granted('ROLE_ADMIN') ? 'Administrator' : 'Verified User' }}</p>
                        </div>
                        {% if app.user.profileImage %}
                            <img src="{{ asset('uploads/profiles/' ~ app.user.profileImage) }}" class="w-10 h-10 rounded-full border shadow-sm">
                        {% else %}
                            <div class="w-10 h-10 rounded-full bg-primary flex items-center justify-center text-white font-bold">
                                {{ app.user.firstName|first }}{{ app.user.lastName|first }}
                            </div>
                        {% endif %}
                    </div>
                {% endif %}
            </div>
        </header>

        <!-- Dynamic Content -->
        <div class="p-8 h-full">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="mb-6 p-4 rounded-2xl flex items-center gap-4 animate-bounce font-bold uppercase tracking-widest text-[10px] border shadow-sm
                        {{ label == 'success' ? 'bg-emerald-50 text-emerald-600 border-emerald-100' : 'bg-red-50 text-red-600 border-red-100' }}">
                         <i class="fa-solid {{ label == 'success' ? 'fa-circle-check' : 'fa-circle-exclamation' }} text-lg"></i>
                         {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}
            {% block content %}{% endblock %}
        </div>
    </main>
{% endblock %}
