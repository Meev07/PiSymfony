{% extends 'base.html.twig' %}

{% block title %}Verify Your Identity | ESPRIT WALLET{% endblock %}

{% block body %}
<div class="flex items-center justify-center min-h-screen bg-slate-50 p-6">
    <div class="max-w-md w-full glass-card p-10 bg-white shadow-2xl rounded-[2.5rem] border border-slate-100 text-center">
        <div class="w-20 h-20 bg-primary/10 text-primary rounded-3xl flex items-center justify-center text-3xl mx-auto mb-6 shadow-sm border border-primary/5">
            <i class="fa-solid fa-shield-halved"></i>
        </div>
        
        <h1 class="text-3xl font-black text-slate-800 uppercase tracking-tight mb-3">Two-Step Verification</h1>
        <p class="text-slate-500 font-medium leading-relaxed mb-8">
            A 6-digit verification code has been dispatched to your institutional email. Enter it below to proceed.
        </p>

        {% for flash_error in app.flashes('error') %}
            <div class="bg-red-50 text-red-600 p-4 rounded-2xl text-xs font-bold uppercase tracking-widest flex items-center gap-3 border border-red-100 mb-6">
                <i class="fa-solid fa-circle-exclamation text-lg"></i>
                {{ flash_error }}
            </div>
        {% endfor %}

        <form method="post" class="space-y-6">
            <div class="space-y-2">
                <label class="block text-xs uppercase font-black text-slate-400 tracking-widest pl-3">Verification Code</label>
                <div class="relative">
                    <i class="fa-solid fa-key absolute left-5 top-5 text-slate-300"></i>
                    <input type="text" name="verification_code" class="w-full bg-slate-50 border border-slate-100 outline-none p-5 pl-14 rounded-2xl font-black text-2xl tracking-[1rem] text-center text-slate-700 focus:ring-2 ring-primary transition border shadow-sm" maxlength="6" pattern="\d{6}" placeholder="000000" required autofocus>
                </div>
            </div>

            <button type="submit" class="w-full gradient-bg text-white py-5 rounded-2xl font-black uppercase tracking-widest hover:shadow-lg transition flex items-center justify-center gap-3 shadow-xl mt-4">
                Verify and Dashboard
            </button>
        </form>

        <div class="mt-8 text-center pt-8 border-t border-slate-50">
            <p class="text-xs text-slate-400 font-medium">
                Didn't receive the code? Check your spam folder or 
                <a href="{{ path('app_logout') }}" class="text-primary font-bold hover:underline">Go back and login again</a>.
            </p>
        </div>
    </div>
</div>
{% endblock %}
