{% extends 'admin/base.html.twig' %}

{% block title %}Manage Accounts | Esprit Admin{% endblock %}
{% block page_title %}Bank Accounts Directory{% endblock %}

{% block body %}
<div class="glass-card">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
        <h2 style="margin: 0;">Bank Accounts</h2>
    </div>

    <div style="overflow-x: auto;">
        <table>
            <thead>
                <tr>
                    <th>Type</th>
                    <th>Account Number</th>
                    <th>Owner</th>
                    <th>Balance</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for acc in accounts %}
                <tr style="{{ acc.status == 'BLOCKED' ? 'background: rgba(239, 68, 68, 0.05);' : '' }}">
                    <td><strong>{{ acc.type }}</strong></td>
                    <td style="font-family: monospace; color: var(--secondary);">{{ acc.accountNumber }}</td>
                    <td>{{ acc.user.firstName }} {{ acc.user.lastName }}</td>
                    <td>{{ acc.balance|number_format(2, '.', ',') }} TND</td>
                    <td>
                        {% if acc.status == 'ACTIVE' %}
                            <span class="badge" style="background: rgba(34, 197, 94, 0.2); color: #22c55e; border: 1px solid rgba(34, 197, 94, 0.3);">
                                <i class="fas fa-check-circle"></i> ACTIVE
                            </span>
                        {% else %}
                            <span class="badge" style="background: rgba(239, 68, 68, 0.2); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.3);">
                                <i class="fas fa-ban"></i> BLOCKED
                            </span>
                        {% endif %}
                    </td>
                    <td>
                        <div style="display: flex; gap: 0.5rem; align-items: center;">
                            <form method="post" action="{{ path('admin_account_toggle_status', {'id': acc.id}) }}" style="display: inline;">
                                {% if acc.status == 'ACTIVE' %}
                                    <button class="btn btn-sm" type="submit" style="background: rgba(239, 68, 68, 0.1); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.2);" title="Block Account">
                                        <i class="fas fa-lock"></i> Block
                                    </button>
                                {% else %}
                                    <button class="btn btn-sm" type="submit" style="background: rgba(34, 197, 94, 0.1); color: #22c55e; border: 1px solid rgba(34, 197, 94, 0.2);" title="Unblock Account">
                                        <i class="fas fa-unlock"></i> Unblock
                                    </button>
                                {% endif %}
                            </form>

                            <form method="post" action="{{ path('admin_account_delete', {'id': acc.id}) }}" onsubmit="return confirm('Are you sure you want to delete this account?');" style="display: inline;">
                                <button class="btn btn-danger btn-sm" type="submit" title="Delete Account">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="6" style="text-align: center; color: var(--text-muted); padding: 2rem;">No accounts found.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

