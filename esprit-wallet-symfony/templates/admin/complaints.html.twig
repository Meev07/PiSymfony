{% extends 'admin/base.html.twig' %}

{% block title %}Manage Complaints | Esprit Admin{% endblock %}
{% block page_title %}User Complaints{% endblock %}

{% block body %}
<div class="glass-card">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
        <h2 style="margin: 0;">Support Tickets</h2>
    </div>

    <div style="overflow-x: auto;">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>User</th>
                    <th>Category</th>
                    <th>Subject</th>
                    <th>Status</th>
                    <th>Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for complaint in complaints %}
                <tr>
                    <td>#{{ complaint.id }}</td>
                    <td>{{ complaint.user.firstName }} {{ complaint.user.lastName }}</td>
                    <td>
                        <span class="badge" style="background: rgba(79, 70, 229, 0.2); color: #818CF8;">{{ complaint.category }}</span>
                    </td>
                    <td style="font-weight: 500;">
                        {{ complaint.title }}
                        {% if complaint.description %}
                            <div style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0.25rem;">{{ complaint.description|slice(0, 50) }}...</div>
                        {% endif %}
                    </td>
                    <td>
                        {% if complaint.status == 'PENDING' %}
                            <span class="badge badge-warning">Pending</span>
                        {% elseif complaint.status == 'RESOLVED' %}
                            <span class="badge badge-success">Resolved</span>
                        {% else %}
                            <span class="badge badge-info">{{ complaint.status }}</span>
                        {% endif %}
                    </td>
                    <td style="font-size: 0.85rem;">{{ complaint.createdAt|date('Y-m-d H:i') }}</td>
                    <td>
                        <div style="display: flex; gap: 0.5rem; align-items: center;">
                            {% if complaint.status != 'RESOLVED' %}
                                <form method="post" action="{{ path('admin_complaint_resolve', {'id': complaint.id}) }}" onsubmit="return confirm('Mark this complaint as resolved?');">
                                    <button class="btn btn-success btn-sm" type="submit" title="Resolve" style="margin: 0;"><i class="fas fa-check-circle"></i></button>
                                </form>
                            {% endif %}
                            <a href="{{ path('admin_complaint_chat', {'id': complaint.id}) }}" class="btn btn-sm" style="{% if complaint.status == 'RESOLVED' %}background: rgba(255,255,255,0.1); color: white;{% else %}background: var(--primary); color: white;{% endif %} margin: 0;">
                                <i class="fas {% if complaint.status == 'RESOLVED' %}fa-eye{% else %}fa-comments{% endif %}"></i> 
                            </a>
                            <form method="post" action="{{ path('admin_complaint_delete', {'id': complaint.id}) }}" onsubmit="return confirm('Are you sure you want to delete this complaint?');">
                                <button class="btn btn-danger btn-sm" type="submit" style="margin: 0;"><i class="fas fa-trash"></i></button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="7" style="text-align: center; color: var(--text-muted); padding: 2rem;">No complaints found.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
