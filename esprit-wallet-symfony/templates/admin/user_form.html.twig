{% extends 'admin/base.html.twig' %}

{% block title %}{{ isEdit ? 'Edit User' : 'New User' }} | Esprit Admin{% endblock %}
{% block page_title %}{{ isEdit ? 'Edit User' : 'Add New User' }}{% endblock %}

{% block stylesheets %}
<style>
    .form-group {
        margin-bottom: 1.5rem;
    }
    .form-label {
        display: block;
        margin-bottom: 0.5rem;
        color: var(--text-muted);
        font-weight: 500;
        font-size: 0.9rem;
    }
    .form-control, .form-control input, .form-control select {
        width: 100%;
        padding: 0.75rem 1rem;
        background: rgba(15, 23, 42, 0.5);
        border: 1px solid var(--border);
        border-radius: 0.8rem;
        color: var(--text-main);
        font-family: inherit;
        transition: all 0.3s ease;
    }
    .form-control:focus-within {
        border-color: var(--primary);
        background: rgba(15, 23, 42, 0.8);
        box-shadow: 0 0 15px rgba(99, 102, 241, 0.2);
    }
    .form-control.is-invalid {
        border-color: #ff4d4d !important;
        background: rgba(255, 77, 77, 0.05);
    }
    .invalid-feedback {
        color: #ff4d4d;
        font-size: 0.82rem;
        margin-top: 0.4rem;
        display: block;
        font-weight: 500;
        animation: slideIn 0.3s ease;
    }
    @keyframes slideIn {
        from { opacity: 0; transform: translateY(-3px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .form-check {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1rem;
        padding: 0.75rem;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 0.5rem;
        border: 1px solid transparent;
        transition: all 0.2s;
    }
    .form-check:hover {
        background: rgba(255, 255, 255, 0.08);
        border-color: rgba(255, 255, 255, 0.1);
    }
    .form-check input {
        width: 1.2rem;
        height: 1.2rem;
        accent-color: var(--primary);
        cursor: pointer;
    }
    .form-check label {
        margin: 0;
        color: white;
        font-size: 0.95rem;
        cursor: pointer;
    }
    .error-container {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
    }
</style>
{% endblock %}

{% block body %}
<div class="glass-card" style="max-width: 800px; padding: 2.5rem;">
    {{ form_start(userForm, {'attr': {'novalidate': 'novalidate'}}) }}
        
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
            <div class="form-group">
                {{ form_label(userForm.firstName, null, {'label_attr': {'class': 'form-label'}}) }}
                <div class="form-control-wrapper">
                    {% set firstNameAttr = {'class': 'form-control' ~ (userForm.firstName.vars.valid ? '' : ' is-invalid')} %}
                    {{ form_widget(userForm.firstName, {'attr': firstNameAttr}) }}
                    <div class="error-container">
                        {% for error in userForm.firstName.vars.errors %}
                            <span class="invalid-feedback"><i class="fas fa-exclamation-circle"></i> {{ error.message }}</span>
                        {% endfor %}
                    </div>
                </div>
            </div>
            
            <div class="form-group">
                {{ form_label(userForm.lastName, null, {'label_attr': {'class': 'form-label'}}) }}
                <div class="form-control-wrapper">
                    {% set lastNameAttr = {'class': 'form-control' ~ (userForm.lastName.vars.valid ? '' : ' is-invalid')} %}
                    {{ form_widget(userForm.lastName, {'attr': lastNameAttr}) }}
                    <div class="error-container">
                        {% for error in userForm.lastName.vars.errors %}
                            <span class="invalid-feedback"><i class="fas fa-exclamation-circle"></i> {{ error.message }}</span>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>

        <div class="form-group">
            {{ form_label(userForm.email, null, {'label_attr': {'class': 'form-label'}}) }}
            {% set emailAttr = {'class': 'form-control' ~ (userForm.email.vars.valid ? '' : ' is-invalid')} %}
            {{ form_widget(userForm.email, {'attr': emailAttr}) }}
            <div class="error-container">
                {% for error in userForm.email.vars.errors %}
                    <span class="invalid-feedback"><i class="fas fa-exclamation-circle"></i> {{ error.message }}</span>
                {% endfor %}
            </div>
        </div>

        {% if userForm.plainPassword is defined %}
        <div class="form-group">
            {{ form_label(userForm.plainPassword, null, {'label_attr': {'class': 'form-label'}}) }}
            {% set passwordAttr = {'class': 'form-control' ~ (userForm.plainPassword.vars.valid ? '' : ' is-invalid')} %}
            {{ form_widget(userForm.plainPassword, {'attr': passwordAttr}) }}
            <div class="error-container">
                {% for error in userForm.plainPassword.vars.errors %}
                    <span class="invalid-feedback"><i class="fas fa-exclamation-circle"></i> {{ error.message }}</span>
                {% endfor %}
            </div>
            <small style="color: var(--text-muted); font-size: 0.8rem; margin-top: 0.5rem; display: block;">
                Minimum 8 characters. Will be securely hashed.
            </small>
        </div>
        {% endif %}

        <div class="form-group">
            <label class="form-label">Account Configuration</label>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 0.5rem;">
                <div class="form-check">
                    {{ form_widget(userForm.isVerified) }}
                    {{ form_label(userForm.isVerified) }}
                </div>
                <div class="form-check">
                    {{ form_widget(userForm.isActive) }}
                    {{ form_label(userForm.isActive) }}
                </div>
            </div>
        </div>


        <div class="form-group">
            {{ form_label(userForm.roles, null, {'label_attr': {'class': 'form-label'}}) }}
            <div style="display: flex; gap: 1.5rem; flex-wrap: wrap; background: rgba(0,0,0,0.2); padding: 1rem; border-radius: 0.8rem; border: 1px solid var(--border);">
                {% for child in userForm.roles %}
                    <div class="form-check" style="background: transparent; padding: 0; margin: 0; border: none;">
                        {{ form_widget(child) }}
                        {{ form_label(child) }}
                    </div>
                {% endfor %}
            </div>
            <div class="error-container">
                {% for error in userForm.roles.vars.errors %}
                    <span class="invalid-feedback"><i class="fas fa-exclamation-circle"></i> {{ error.message }}</span>
                {% endfor %}
            </div>
        </div>

        <div style="margin-top: 3rem; display: flex; gap: 1.2rem; border-top: 1px solid var(--border); padding-top: 2rem;">
            <button type="submit" class="btn btn-primary" style="padding: 0.8rem 2rem;">
                <i class="fas fa-save" style="margin-right: 8px;"></i> 
                {{ isEdit ? 'Update User' : 'Create User' }}
            </button>
            <a href="{{ path('admin_users') }}" class="btn" style="background: rgba(255,255,255,0.05); color: white; padding: 0.8rem 2rem; border: 1px solid var(--border);">
                Cancel
            </a>
        </div>
    {{ form_end(userForm) }}
</div>
{% endblock %}


