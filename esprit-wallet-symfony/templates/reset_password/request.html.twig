{% extends 'base.html.twig' %}

{% block title %}Reset Your Password | ESPRIT WALLET{% endblock %}

{% block body %}
<div class="flex items-center justify-center min-h-screen bg-slate-50 p-6">
    <div class="max-w-md w-full glass-card p-10 bg-white shadow-2xl rounded-[2.5rem] border border-slate-100">
        <div class="text-center mb-10">
            <div class="w-20 h-20 gradient-bg rounded-3xl flex items-center justify-center text-white text-3xl mx-auto mb-6 shadow-lg rotate-3 hover:rotate-0 transition-transform duration-500">
                <i class="fa-solid fa-key"></i>
            </div>
            <h1 class="text-3xl font-black text-slate-800 uppercase tracking-tight mb-3">Forgot Password?</h1>
            <p class="text-slate-500 font-medium leading-relaxed">Enter your email address and we'll send you a secure link to reset your access.</p>
        </div>

        {% for flash_error in app.flashes('reset_password_error') %}
            <div class="bg-red-50 text-red-600 p-4 rounded-2xl text-xs font-bold uppercase tracking-widest flex items-center gap-3 border border-red-100 mb-6">
                <i class="fa-solid fa-circle-exclamation text-lg"></i>
                {{ flash_error }}
            </div>
        {% endfor %}

        {{ form_start(requestForm, {'attr': {'class': 'space-y-6'}}) }}
            <div class="space-y-2">
                <label class="block text-xs uppercase font-black text-slate-400 tracking-widest pl-3">Institutional Email</label>
                <div class="relative">
                    <i class="fa-solid fa-envelope absolute left-5 top-5 text-slate-300"></i>
                    {{ form_widget(requestForm.email, {
                        'attr': {
                            'class': 'w-full bg-slate-50 border border-slate-100 outline-none p-5 pl-14 rounded-2xl font-bold text-slate-700 focus:ring-2 ring-primary transition border shadow-sm',
                            'placeholder': 'name@esprit.tn'
                        }
                    }) }}
                    {% if form_errors(requestForm.email) %}
                        <div class="text-red-500 text-[10px] font-black uppercase tracking-widest mt-2 pl-3">
                            {{ form_errors(requestForm.email) }}
                        </div>
                    {% endif %}
                </div>
            </div>

            <button type="submit" class="w-full gradient-bg text-white py-5 rounded-2xl font-black uppercase tracking-widest hover:shadow-lg transition flex items-center justify-center gap-3 shadow-xl group">
                Send Reset Link
                <i class="fa-solid fa-paper-plane group-hover:translate-x-1 transition-transform"></i>
            </button>
        {{ form_end(requestForm) }}

        <div class="mt-8 text-center pt-8 border-t border-slate-50">
            <a href="{{ path('app_login') }}" class="text-sm font-black text-primary uppercase tracking-widest hover:gap-3 transition-all flex items-center justify-center gap-2">
                <i class="fa-solid fa-arrow-left"></i> Back to Login
            </a>
        </div>
    </div>
</div>
{% endblock %}
