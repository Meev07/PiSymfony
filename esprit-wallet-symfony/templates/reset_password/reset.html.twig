{% extends 'base.html.twig' %}

{% block title %}Set New Password | ESPRIT WALLET{% endblock %}

{% block body %}
<div class="flex items-center justify-center min-h-screen bg-slate-50 p-6">
    <div class="max-w-md w-full glass-card p-10 bg-white shadow-2xl rounded-[2.5rem] border border-slate-100">
        <div class="text-center mb-10">
            <div class="w-20 h-20 bg-primary/10 text-primary rounded-3xl flex items-center justify-center text-3xl mx-auto mb-6 shadow-sm border border-primary/5">
                <i class="fa-solid fa-shield-halved"></i>
            </div>
            <h1 class="text-3xl font-black text-slate-800 uppercase tracking-tight mb-3">Secure Reset</h1>
            <p class="text-slate-500 font-medium leading-relaxed">Establish a new, complex password to regain access to your Esprit Wallet.</p>
        </div>

        {{ form_start(resetForm, {'attr': {'class': 'space-y-6'}}) }}
            
            <div class="space-y-2">
                <label class="block text-xs uppercase font-black text-slate-400 tracking-widest pl-3">New Password</label>
                <div class="relative">
                    <i class="fa-solid fa-lock absolute left-5 top-5 text-slate-300"></i>
                    {{ form_widget(resetForm.plainPassword.first, {
                        'attr': {
                            'class': 'w-full bg-slate-50 border border-slate-100 outline-none p-5 pl-14 rounded-2xl font-bold text-slate-700 focus:ring-2 ring-primary transition border shadow-sm',
                            'placeholder': '••••••••••••'
                        }
                    }) }}
                </div>
            </div>

            <div class="space-y-2">
                <label class="block text-xs uppercase font-black text-slate-400 tracking-widest pl-3">Confirm Password</label>
                <div class="relative">
                    <i class="fa-solid fa-circle-check absolute left-5 top-5 text-slate-300"></i>
                    {{ form_widget(resetForm.plainPassword.second, {
                        'attr': {
                            'class': 'w-full bg-slate-50 border border-slate-100 outline-none p-5 pl-14 rounded-2xl font-bold text-slate-700 focus:ring-2 ring-primary transition border shadow-sm',
                            'placeholder': '••••••••••••'
                        }
                    }) }}
                </div>
            </div>

            {% if not resetForm.plainPassword.vars.valid %}
                <div class="bg-red-50 text-red-600 p-4 rounded-2xl text-[10px] font-bold uppercase tracking-widest leading-loose border border-red-100 italic">
                    {{ form_errors(resetForm.plainPassword.first) }}
                </div>
            {% endif %}

            <button type="submit" class="w-full gradient-bg text-white py-5 rounded-2xl font-black uppercase tracking-widest hover:shadow-lg transition flex items-center justify-center gap-3 shadow-xl mt-4">
                Update Security Credentials
            </button>
        {{ form_end(resetForm) }}

        <div class="mt-8 text-center pt-8 border-t border-slate-50">
            <p class="text-[10px] font-black uppercase tracking-tighter text-slate-300">
                <i class="fa-solid fa-shield-virus mr-1"></i> End-to-end Encrypted Reset
            </p>
        </div>
    </div>
</div>
{% endblock %}
