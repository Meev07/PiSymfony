{% extends 'app_layout.html.twig' %}

{% block title %}Support Center | ESPRIT WALLET{% endblock %}

{% block content %}
<div class="flex items-center justify-between mb-8">
    <h1 class="text-3xl font-extrabold text-slate-800 tracking-tight flex items-center gap-4 uppercase">
        <i class="fa-solid fa-headset text-primary"></i>
        Support & Complaints
    </h1>
    <a href="{{ path('app_complaint_new') }}" class="gradient-bg text-white px-8 py-3 rounded-2xl font-black uppercase tracking-widest text-sm hover:shadow-lg transition flex items-center gap-3">
        <i class="fa-solid fa-plus-circle"></i> Create Complaint
    </a>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <div class="lg:col-span-2 space-y-6">
        {% for complaint in complaints %}
            <div class="bg-white rounded-3xl p-6 border card-shadow flex gap-6 group hover:border-primary/30 transition">
                <div class="flex flex-col items-center">
                    <div class="w-14 h-14 rounded-2xl bg-slate-50 flex items-center justify-center text-slate-400 font-bold mb-3">
                         <i class="fa-solid fa-file-invoice text-2xl group-hover:text-primary transition"></i>
                    </div>
                </div>
                <div class="flex-1">
                    <div class="flex items-center justify-between mb-2 pb-2 border-b">
                         <div>
                            <span class="text-[9px] font-black uppercase text-primary tracking-widest">{{ complaint.category }}</span>
                            <h3 class="font-extrabold text-slate-800 text-lg uppercase tracking-tighter -mt-1">{{ complaint.title }}</h3>
                         </div>
                         <span class="px-3 py-1 rounded-full font-bold text-[9px] uppercase tracking-wide
                            {{ complaint.status == 'PENDING' ? 'bg-amber-100 text-amber-600' : 
                               complaint.status == 'RESOLVED' ? 'bg-emerald-100 text-emerald-600' : 
                               complaint.status == 'CLOSED' ? 'bg-slate-100 text-slate-600' : 'bg-blue-100 text-blue-600' }}">
                            {{ complaint.status }}
                        </span>
                    </div>
                    <p class="text-sm text-slate-500 leading-relaxed mb-4">{{ complaint.description|slice(0, 150) }}...</p>
                    <div class="flex items-center justify-between">
                        <span class="text-[10px] text-slate-400 font-bold uppercase"><i class="fa-solid fa-clock mr-1 opacity-50"></i> {{ complaint.createdAt|date('M d, Y') }}</span>
                        <div class="flex gap-2">
                             <a href="{{ path('app_complaint_show', {'id': complaint.id}) }}" class="px-4 py-1.5 bg-slate-50 hover:bg-primary hover:text-white rounded-lg text-[10px] font-black uppercase tracking-widest transition border">Details</a>
                             {% if complaint.status == 'PENDING' %}
                                <a href="{{ path('app_complaint_edit', {'id': complaint.id}) }}" class="px-4 py-1.5 bg-slate-50 hover:bg-amber-500 hover:text-white rounded-lg text-[10px] font-black uppercase tracking-widest transition border">Edit</a>
                             {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
             <div class="bg-white rounded-3xl p-20 border-2 border-dashed border-slate-200 text-center">
                 <div class="text-slate-200 text-7xl mb-6"><i class="fa-solid fa-clipboard-question"></i></div>
                 <h2 class="text-xl font-bold text-slate-400 uppercase tracking-widest">No complaints found.</h2>
                 <p class="text-sm text-slate-400 max-w-sm mx-auto mt-2">If you have any issues with your transactions, accounts, or cheques, please open a support ticket.</p>
             </div>
        {% endfor %}
    </div>

    <!-- Support Sidebar -->
    <div class="space-y-6">
        <div class="bg-primary rounded-3xl p-8 text-white card-shadow overflow-hidden relative">
            <h3 class="font-black text-xl mb-4 tracking-tighter uppercase">Support Information</h3>
            <p class="text-white/70 text-sm mb-6 leading-relaxed">Most complaints are processed within 24 business hours. You will receive a notification as soon as an agent responds.</p>
            <div class="space-y-4">
                <div class="flex items-center gap-4">
                    <i class="fa-solid fa-phone text-white/30 text-xl"></i>
                    <span class="text-sm font-bold tracking-widest opacity-90">+216 71 000 000</span>
                </div>
                <div class="flex items-center gap-4">
                    <i class="fa-solid fa-envelope text-white/30 text-xl"></i>
                    <span class="text-sm font-bold tracking-widest opacity-90">support@espritwallet.tn</span>
                </div>
            </div>
            <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-white/10 rounded-full blur-3xl"></div>
        </div>
        
        <div class="bg-white rounded-3xl p-8 border card-shadow">
            <h4 class="font-bold text-slate-800 mb-6 uppercase tracking-wider text-xs border-b pb-4">Helpful Articles</h4>
            <ul class="space-y-4">
                <li><a href="#" class="text-sm font-bold text-slate-600 hover:text-primary transition flex items-center gap-3"><i class="fa-solid fa-chevron-right text-[10px] text-slate-300"></i> How to redeem a cheque</a></li>
                <li><a href="#" class="text-sm font-bold text-slate-600 hover:text-primary transition flex items-center gap-3"><i class="fa-solid fa-chevron-right text-[10px] text-slate-300"></i> Disputing a transaction</a></li>
                <li><a href="#" class="text-sm font-bold text-slate-600 hover:text-primary transition flex items-center gap-3"><i class="fa-solid fa-chevron-right text-[10px] text-slate-300"></i> Freeze a lost card/account</a></li>
            </ul>
        </div>
    </div>
</div>
{% endblock %}
