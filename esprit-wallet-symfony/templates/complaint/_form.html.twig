{{ form_start(form) }}
    <div class="space-y-6 px-10 pb-12 pt-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="p-6 {{ form_errors(form.category) ? 'bg-red-50 border-red-200' : 'bg-slate-50 border-slate-100' }} border rounded-2xl space-y-4">
                <div class="flex items-center justify-between px-3">
                    <label class="block text-xs uppercase font-black text-slate-400 tracking-widest pl-3">Issue Category</label>
                    {% if form_errors(form.category) %}
                        <span class="text-[9px] font-black text-red-500 uppercase tracking-widest">Required</span>
                    {% endif %}
                </div>
                {{ form_widget(form.category, {'attr': {'class': 'w-full bg-white border border-slate-200 outline-none p-4 rounded-2xl font-bold text-slate-700 focus:ring-2 ring-primary transition'}}) }}
                {{ form_errors(form.category, {'attr': {'class': 'text-red-500 font-bold mt-1 text-[10px] pl-3'}}) }}
            </div>
            <div class="p-6 {{ form_errors(form.title) ? 'bg-red-50 border-red-200' : 'bg-slate-50 border-slate-100' }} border rounded-2xl space-y-4">
                <div class="flex items-center justify-between px-3">
                    <label class="block text-xs uppercase font-black text-slate-400 tracking-widest pl-3">Complaint Title</label>
                    {% if form_errors(form.title) %}
                        <span class="text-[9px] font-black text-red-500 uppercase tracking-widest">Required</span>
                    {% endif %}
                </div>
                {{ form_widget(form.title, {'attr': {'class': 'w-full bg-white border border-slate-200 outline-none p-4 rounded-2xl font-bold text-slate-700 focus:ring-2 ring-primary transition'}}) }}
                {{ form_errors(form.title, {'attr': {'class': 'text-red-500 font-bold mt-1 text-[10px] pl-3'}}) }}
            </div>
        </div>

        <div class="p-6 {{ form_errors(form.description) ? 'bg-red-50 border-red-200' : 'bg-slate-50 border-slate-100' }} border rounded-2xl space-y-4">
            <div class="flex items-center justify-between px-3">
                <label class="block text-xs uppercase font-black text-slate-400 tracking-widest pl-3">Detailed Description</label>
                {% if form_errors(form.description) %}
                    <span class="text-[9px] font-black text-red-500 uppercase tracking-widest">Detailed explanation required</span>
                {% endif %}
            </div>
            {{ form_widget(form.description, {'attr': {'class': 'w-full bg-white border border-slate-200 outline-none p-6 rounded-2xl text-slate-700 min-h-[200px] focus:ring-2 ring-primary transition', 'placeholder': 'Describe your issue in detail...'}}) }}
            {{ form_errors(form.description, {'attr': {'class': 'text-red-500 font-bold mt-1 text-[10px] pl-3'}}) }}
        </div>

        <div class="flex items-center gap-4">
            <button class="flex-1 {{ button_color|default('gradient-bg') }} text-white py-5 rounded-2xl font-black uppercase tracking-widest hover:shadow-lg transition flex items-center justify-center gap-2">
                <i class="fa-solid {{ button_icon|default('fa-headset') }}"></i> {{ button_label|default('Submit Complaint') }}
            </button>
            <a href="{{ path('app_complaint_index') }}" class="px-10 py-5 bg-slate-100 text-slate-400 hover:text-slate-600 rounded-2xl font-bold transition">
                Cancel
            </a>
        </div>
    </div>
{{ form_end(form) }}
