{% extends 'admin_layout.html.twig' %}

{% block title %}User Details{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item"><a href="{{ path('app_admin_dashboard') }}">Home</a></li>
    <li class="breadcrumb-item"><a href="{{ path('app_admin_user_index') }}">Users</a></li>
    <li class="breadcrumb-item active" aria-current="page">Details</li>
{% endblock %}

{% block body %}
<div class="row h-100">
    <div class="col-lg-4 mb-4">
        <!-- User Profile Info -->
        <div class="card shadow-sm border-0 rounded-3 text-center p-4">
            <div class="bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-3 mx-auto" style="width: 80px; height: 80px;">
                <i class="fa-solid fa-user-tie fa-3x text-primary"></i>
            </div>
            <h4 class="fw-bold mb-1">{{ user.name }}</h4>
            <p class="text-muted mb-3">{{ user.email }}</p>
            
            <div class="d-flex justify-content-center gap-2 mb-4">
                {% for role in user.roles %}
                    <span class="badge {% if role == 'ROLE_ADMIN' %}bg-danger{% else %}bg-info text-dark{% endif %} rounded-pill">
                        {{ role|replace({'ROLE_': ''}) }}
                    </span>
                {% endfor %}
            </div>

            <hr>
            
            <div class="d-grid">
                {% if user != app.user %}
                <form method="post" action="{{ path('app_admin_user_delete', {'id': user.id}) }}" onsubmit="return confirm('Delete this user?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                    <button class="btn btn-outline-danger w-100">
                        <i class="fa-solid fa-trash-can me-2"></i>Delete User
                    </button>
                </form>
                {% endif %}
                <a href="{{ path('app_admin_user_index') }}" class="btn btn-light mt-2">
                    <i class="fa-solid fa-arrow-left me-2"></i>Back to List
                </a>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <!-- User Profile Details -->
        <div class="card shadow-sm border-0 rounded-3">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold"><i class="fa-solid fa-address-card me-2 text-primary"></i>Account Information</h5>
            </div>
            <div class="card-body p-4">
                <div class="row g-4">
                    <div class="col-md-6">
                        <label class="text-muted small text-uppercase fw-bold">Full Name</label>
                        <p class="h6 mb-0">{{ user.name }}</p>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small text-uppercase fw-bold">Email Address</label>
                        <p class="h6 mb-0">{{ user.email }}</p>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small text-uppercase fw-bold">Current Account Status</label>
                        <p class="mb-0">
                            <span class="badge bg-success rounded-pill px-3">Active</span>
                        </p>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small text-uppercase fw-bold">System Permissions</label>
                        <p class="mb-0">
                            {% for role in user.roles %}
                                <span class="badge bg-secondary me-1">{{ role }}</span>
                            {% endfor %}
                        </p>
                    </div>
                </div>

                <div class="alert alert-info mt-5 border-0 shadow-sm rounded-3 p-4 d-flex align-items-center">
                    <div class="me-4 h3 mb-0">
                        <i class="fas fa-info-circle"></i>
                    </div>
                    <div>
                        <h6 class="mb-1 fw-bold">Note for Administrators</h6>
                        <p class="mb-0 small opacity-75">The card management functionality has been disabled for this member. To re-enable banking cards, please consult the system global configuration.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
