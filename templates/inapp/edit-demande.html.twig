<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <title>Modifier demande - InApp Credit Dashboard</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
   <link rel="apple-touch-icon" sizes="180x180" href="./assets/images/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="32x32" href="./assets/images/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="./assets/images/favicon-16x16.png">
  <link rel="manifest" href="./assets/site.webmanifest">
  <script type="module" crossorigin src="./assets/js/main.js"></script>
  <link rel="stylesheet" crossorigin href="./assets/css/main.css">
</head>

<body>
  <div id="overlay" class="overlay"></div>
  <!-- TOPBAR -->
  <nav id="topbar" class="navbar bg-white border-bottom fixed-top topbar px-3">

  </nav>

  <!-- SIDEBAR -->
  <aside id="sidebar" class="sidebar">
    <div class="logo-area">
      <a href="index.html" class="d-inline-flex lh-sm">
        <span class="fw-bold fs-5 text-primary">Esprit Wallet</span>
      </a>
    </div>
    <ul class="nav flex-column">
      <li class="px-4 py-2"><small class="nav-text">Main</small></li>
      <li><a class="nav-link" href="credit.html"><i class="ti ti-box-seam"></i><span
        class="nav-text">Credit</span></a></li>
      <li><a class="nav-link" href="create-demande.html"><i class="ti ti-plus"></i><span class="nav-text">Ajouter
        demande</span></a></li>

  <li><a class="nav-link" href="signin.html"><i class="ti ti-logout"></i><span class="nav-text">Log out</span></a></li>
    </ul>

  </aside>

  <!-- MAIN CONTENT -->
  <main id="content" class="content py-10">
    <div class="container-fluid">
      <div class="row">
        <div class="col-12">
          <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
            <div class="">
              <h1 class="fs-3 mb-1">Modifier une demande du Credit</h1>
              <p class="mb-0">Modifier ce formulaire</p>
            </div>
            <div>
              <a href="credit.html" class="btn btn-primary">Retour vers liste</a>
            </div>
          </div>
        </div>
      </div>
      <div class="row">
        <div class="col-12">
          <div class="card">
            <div class="card-body p-4">
              {% if error %}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                  <strong>Erreur!</strong> {{ error }}
                  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
              {% endif %}
              
              {% if success %}
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                  <strong>Succès!</strong> Votre demande de crédit a été modifiée avec succès.
                  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
              {% endif %}

              <form method="POST" action="{{ path('app_edit_demande_submit', {'id': demande.id_dossier}) }}" id="editCreditForm">
                <!-- Numéro de dossier (lecture seule) -->
                <div class="row">
                  <div class="col-md-6 mb-3">
                    <label class="form-label">Numéro de dossier</label>
                    <input type="text" class="form-control" value="{{ demande.num_dossier }}" readonly>
                    <small class="text-muted">Numéro unique non modifiable</small>
                  </div>
                  
                  <!-- Statut (lecture seule) -->
                  <div class="col-md-6 mb-3">
                    <label class="form-label">Statut</label>
                    <input type="text" class="form-control" 
                           value="{% if demande.status == 0 %}En attente{% elseif demande.status == 1 %}Approuvé{% else %}Rejeté{% endif %}" 
                           readonly>
                  </div>
                </div>

                <!-- Montant du crédit -->
                <div class="row">
                  <div class="col-md-6 mb-3">
                    <label for="montantDemande" class="form-label">Montant du crédit demandé (DT) <span class="text-danger">*</span></label>
                    <input type="number" class="form-control" id="montantDemande" name="montant_demande" 
                           placeholder="Entrez le montant" step="0.01" min="100" max="500000" 
                           value="{{ demande.montant_demande }}" required>
                    <small class="text-muted">Minimum: 100 DT, Maximum: 500 000 DT</small>
                  </div>
                  
                  <!-- Durée du crédit -->
                  <div class="col-md-6 mb-3">
                    <label for="dureeMois" class="form-label">Durée du crédit (mois) <span class="text-danger">*</span></label>
                    <input type="number" class="form-control" id="dureeMois" name="duree_mois" 
                           placeholder="Nombre de mois" min="1" max="360" 
                           value="{{ demande.duree_mois }}" required>
                    <small class="text-muted">Entre 1 et 360 mois</small>
                  </div>
                </div>

                <!-- Taux d'intérêt -->
                <div class="row">
                  <div class="col-md-6 mb-3">
                    <label for="tauxInteret" class="form-label">Taux d'intérêt annuel (%) <span class="text-danger">*</span></label>
                    <input type="number" class="form-control" id="tauxInteret" name="taux_interet" 
                           value="13" step="0.01" readonly>
                    <small class="text-muted">Taux fixe: 13% par an</small>
                  </div>
                  
                  <!-- Montant mensuel calculé -->
                  <div class="col-md-6 mb-3">
                    <label for="montantMensuel" class="form-label">Montant mensuel estimé (DT)</label>
                    <input type="number" class="form-control" id="montantMensuel" name="montant_mensuel" 
                           placeholder="Calculé automatiquement" step="0.01" readonly
                           value="{{ demande.montant_mensuel }}">
                    <small class="text-muted">Calculé en fonction des paramètres</small>
                  </div>
                </div>

                <!-- Boutons -->
                <div class="d-flex gap-2">
                  <button type="submit" class="btn btn-primary">Mettre à jour</button>
                  <a href="credit.html" class="btn btn-outline-secondary">Annuler</a>
                </div>

              </form>
            </div>
          </div>


        </div>

      </div>

      <div class="row">
        <div class="col-12">
          <footer class="text-center py-2 mt-6 text-white">
            <p class="mb-0">Copyright © 2026 InApp Credit Dashboard. Developed by <a href="https://codescandy.com/" target="_blank" class="text-white">CodesCandy</a> • Distributed by <a href="https://themewagon.com/" target="_blank" class="text-white">ThemeWagon</a> </p>
          </footer>
        </div>

      </div>

    </div>
  </main>

  <!-- Bootstrap JS -->

  <script>
    // Fonction pour calculer le montant mensuel avec intérêts composés
    function calculerMontantMensuel() {
      const montant = parseFloat(document.getElementById('montantDemande').value) || 0;
      const duree = parseInt(document.getElementById('dureeMois').value) || 0;
      const tauxAnnuel = parseFloat(document.getElementById('tauxInteret').value) || 0;
      
      if (montant > 0 && duree > 0 && tauxAnnuel >= 0) {
        // Convertir le taux annuel en taux mensuel
        const tauxMensuel = tauxAnnuel / 100 / 12;
        
        let monthlyPayment;
        if (tauxMensuel === 0) {
          // Si aucun intérêt
          monthlyPayment = montant / duree;
        } else {
          // Formule: M = P * [r(1+r)^n] / [(1+r)^n - 1]
          const numerateur = tauxMensuel * Math.pow(1 + tauxMensuel, duree);
          const denominateur = Math.pow(1 + tauxMensuel, duree) - 1;
          monthlyPayment = montant * (numerateur / denominateur);
        }
        
        document.getElementById('montantMensuel').value = monthlyPayment.toFixed(2);
      } else {
        document.getElementById('montantMensuel').value = '';
      }
    }
    
    // Écouter les changements
    document.getElementById('montantDemande').addEventListener('input', calculerMontantMensuel);
    document.getElementById('dureeMois').addEventListener('input', calculerMontantMensuel);
    
    // Calculer au chargement de la page
    window.addEventListener('load', calculerMontantMensuel);
    
    // Validation du formulaire
    document.getElementById('editCreditForm').addEventListener('submit', function(e) {
      const montant = parseFloat(document.getElementById('montantDemande').value);
      const duree = parseInt(document.getElementById('dureeMois').value);
      const taux = parseFloat(document.getElementById('tauxInteret').value);
      
      if (montant <= 0 || duree <= 0 || taux < 0) {
        e.preventDefault();
        alert('Veuillez vérifier les valeurs saisies.');
        return false;
      }
    });
  </script>

</body>

</html>
