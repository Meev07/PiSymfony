<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <title>Create demande - InApp Credit Dashboard</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
   <link rel="apple-touch-icon" sizes="180x180" href="./assets/images/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="32x32" href="./assets/images/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="./assets/images/favicon-16x16.png">
  <link rel="manifest" href="./assets/site.webmanifest">
  <script type="module" crossorigin src="./assets/js/main.js"></script>
  <link rel="stylesheet" crossorigin href="./assets/css/main.css">
</head>

<body>
  <div id="overlay" class="overlay"></div>
  <!-- TOPBAR -->
  <nav id="topbar" class="navbar bg-white border-bottom fixed-top topbar px-3">

  </nav>

  <!-- SIDEBAR -->
  <aside id="sidebar" class="sidebar">
    <div class="logo-area">
      <a href="{{ path('app_template_page', {'page': 'credit'}) }}" class="d-inline-flex lh-sm">
        <span class="fw-bold fs-5 text-primary">Esprit Wallet</span>
      </a>
    </div>
    <ul class="nav flex-column">
      <li class="px-4 py-2"><small class="nav-text">Main</small></li>
      <li><a class="nav-link" href="{{ path('app_template_page', {'page': 'credit'}) }}"><i class="ti ti-box-seam"></i><span
        class="nav-text">Credit</span></a></li>
      <li><a class="nav-link" href="{{ path('app_template_page', {'page': 'create-demande'}) }}"><i class="ti ti-plus"></i><span class="nav-text">Ajouter
        demande</span></a></li>

  <li><a class="nav-link" href="{{ path('app_signin') }}"><i class="ti ti-logout"></i><span class="nav-text">Log out</span></a></li>
    </ul>

  </aside>

  <!-- MAIN CONTENT -->
  <main id="content" class="content py-10">
    <div class="container-fluid">
      <div class="row">
        <div class="col-12">
          <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
            <div class="">
              <h1 class="fs-3 mb-1">Ajouter une demande du Credit</h1>
              <p class="mb-0">Remplir ce formulaire</p>
            </div>
            <div>
              <a href="{{ path('app_template_page', {'page': 'credit'}) }}" class="btn btn-primary">Allez vers liste des demandes</a>
            </div>
          </div>
        </div>
      </div>
      <div class="row">
        <div class="col-12">
          <div class="card">
            <div class="card-body p-4">
              {% if successMessage %}
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                  <strong>Succès!</strong> {{ successMessage }}
                  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
              {% endif %}

              {% if errorMessage %}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                  <strong>Erreur!</strong> {{ errorMessage }}
                  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
              {% endif %}

              {% if error %}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                  <strong>Erreur!</strong> {{ error }}
                  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
              {% endif %}
              
              {% if success %}
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                  <strong>Succès!</strong> Votre demande de crédit a été créée avec succès.
                  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
              {% endif %}

              {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'id': 'createCreditForm'}}) }}
                <!-- Montant du crédit -->
                <div class="row">
                  <div class="col-md-6 mb-3">
                    {{ form_label(form.montant_demande) }}<span class="text-danger"> *</span>
                    {{ form_widget(form.montant_demande) }}
                    {{ form_errors(form.montant_demande) }}
                    <small class="text-muted">Minimum: 100 DT, Maximum: 500 000 DT</small>
                  </div>

                  <!-- Durée du crédit -->
                  <div class="col-md-6 mb-3">
                    {{ form_label(form.duree_mois) }}<span class="text-danger"> *</span>
                    {{ form_widget(form.duree_mois) }}
                    {{ form_errors(form.duree_mois) }}
                    <small class="text-muted">Entre 1 et 360 mois</small>
                  </div>
                </div>

                <!-- Taux d'intérêt -->
                <div class="row">
                  <div class="col-md-6 mb-3">
                    {{ form_label(form.taux_interet) }}<span class="text-danger"> *</span>
                    {{ form_widget(form.taux_interet) }}
                    {{ form_errors(form.taux_interet) }}
                    <small class="text-muted">Taux fixe: 13% par an</small>
                  </div>

                  <!-- Montant mensuel calculé (champ d'affichage uniquement, hors FormType) -->
                  <div class="col-md-6 mb-3">
                    <label for="montantMensuel" class="form-label">Montant mensuel estimé (DT)</label>
                    <input type="number" class="form-control" id="montantMensuel"
                           placeholder="Calculé automatiquement" step="0.01" readonly>
                    <small class="text-muted">Calculé en fonction des paramètres</small>
                  </div>
                </div>

                <!-- Objet du crédit -->
                <div class="mb-3">
                  {{ form_label(form.objet_credit) }}<span class="text-danger"> *</span>
                  {{ form_widget(form.objet_credit) }}
                  {{ form_errors(form.objet_credit) }}
                </div>

                <!-- Description -->
                <div class="mb-3">
                  {{ form_label(form.description) }}<span class="text-danger"> *</span>
                  {{ form_widget(form.description) }}
                  {{ form_errors(form.description) }}
                  <small class="text-muted">Entre 10 et 500 caractères</small>
                </div>

                <!-- Boutons -->
                <div class="d-flex gap-2">
                  {{ form_widget(form.soumettre) }}
                  <button type="reset" class="btn btn-secondary">Réinitialiser</button>
                  <a href="{{ path('app_template_page', {'page': 'credit'}) }}" class="btn btn-outline-secondary">Retour</a>
                </div>

              {{ form_end(form) }}
            </div>
          </div>


        </div>

      </div>

      <div class="row">
        <div class="col-12">
          <footer class="text-center py-2 mt-6 text-white">
            <p class="mb-0">Copyright © 2026 InApp Credit Dashboard. Developed by <a href="https://codescandy.com/" target="_blank" class="text-white">CodesCandy</a> • Distributed by <a href="https://themewagon.com/" target="_blank" class="text-white">ThemeWagon</a> </p>
          </footer>
        </div>

      </div>

    </div>
  </main>

  <!-- Bootstrap JS -->

  <script>
    // Fonction pour calculer le montant mensuel avec intérêts composés
    function calculerMontantMensuel() {
      const montant = parseFloat(document.getElementById('dossier_credit_montant_demande').value) || 0;
      const duree = parseInt(document.getElementById('dossier_credit_duree_mois').value) || 0;
      const tauxAnnuel = parseFloat(document.getElementById('dossier_credit_taux_interet').value) || 0;
      
      if (montant > 0 && duree > 0 && tauxAnnuel >= 0) {
        // Convertir le taux annuel en taux mensuel
        const tauxMensuel = tauxAnnuel / 100 / 12;
        
        let monthlyPayment;
        if (tauxMensuel === 0) {
          // Si aucun intérêt
          monthlyPayment = montant / duree;
        } else {
          // Formule: M = P * [r(1+r)^n] / [(1+r)^n - 1]
          const numerateur = tauxMensuel * Math.pow(1 + tauxMensuel, duree);
          const denominateur = Math.pow(1 + tauxMensuel, duree) - 1;
          monthlyPayment = montant * (numerateur / denominateur);
        }
        
        document.getElementById('montantMensuel').value = monthlyPayment.toFixed(2);
      } else {
        document.getElementById('montantMensuel').value = '';
      }
    }
    
    // Écouter les changements
    document.getElementById('dossier_credit_montant_demande').addEventListener('input', calculerMontantMensuel);
    document.getElementById('dossier_credit_duree_mois').addEventListener('input', calculerMontantMensuel);

    document.getElementById('createCreditForm').addEventListener('submit', function() {
      const submitButton = document.getElementById('dossier_credit_soumettre');
      if (!submitButton) {
        return;
      }

      submitButton.disabled = true;
      submitButton.textContent = 'Soumission...';
    });
    
    // Calculer au chargement de la page
    window.addEventListener('load', calculerMontantMensuel);
  </script>


</body>

</html>
