<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <title>Credit - InApp Credit Dashboard</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
   <link rel="apple-touch-icon" sizes="180x180" href="./assets/images/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="32x32" href="./assets/images/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="./assets/images/favicon-16x16.png">
  <link rel="manifest" href="./assets/site.webmanifest">
  <script type="module" crossorigin src="./assets/js/main.js"></script>
  <link rel="stylesheet" crossorigin href="./assets/css/main.css">
</head>

<body>
  <div id="overlay" class="overlay"></div>
  <!-- TOPBAR -->
  <nav id="topbar" class="navbar bg-white border-bottom fixed-top topbar px-3">

  </nav>

  <!-- SIDEBAR -->
  <aside id="sidebar" class="sidebar">
     <div class="logo-area">
      <a href="{{ path('app_template_page', {'page': 'credit'}) }}" class="d-inline-flex lh-sm">
        <span class="fw-bold fs-5 text-primary">Esprit Wallet</span>
      </a>
    </div>
    <ul class="nav flex-column">
      <li class="px-4 py-2"><small class="nav-text">Main</small></li>
      <li><a class="nav-link" href="{{ path('app_template_page', {'page': 'credit'}) }}"><i class="ti ti-box-seam"></i><span
        class="nav-text">Credit</span></a></li>
      <li><a class="nav-link" href="{{ path('app_template_page', {'page': 'create-demande'}) }}"><i class="ti ti-plus"></i><span class="nav-text">Ajouter
        demande</span></a></li>
      {% if isAdmin|default(false) %}
      <li><a class="nav-link" href="{{ path('app_retard_prediction') }}"><i class="ti ti-robot"></i><span class="nav-text">Chatbot Retard</span></a></li>
      {% endif %}

  <li><a class="nav-link" href="{{ path('app_signin') }}"><i class="ti ti-logout"></i><span class="nav-text">Log out</span></a></li>
    </ul>

  </aside>

  <!-- MAIN CONTENT -->
  <main id="content" class="content py-10">
    <div class="container-fluid">
      <div class="row">
        <div class="col-12">
          {% if successMessage %}
          <div class="alert alert-success" role="alert">
            {{ successMessage }}
          </div>
          {% endif %}

          {% if errorMessage %}
          <div class="alert alert-danger" role="alert">
            {{ errorMessage }}
          </div>
          {% endif %}

          <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="">
              <h1 class="fs-3 mb-1">Credit</h1>
              <p class="mb-0">Consulter vos demandes de credit</p>
            </div>
            <div>
              <a href="{{ path('app_template_page', {'page': 'create-demande'}) }}" class="btn btn-primary">Ajouter demande</a>
            </div>
          </div>
        </div>
      </div>
      <div class="row">
        <div class="col-12">
          {{ form_start(searchForm, {
            action: path('app_credit_search_submit'),
            attr: {
              class: 'card p-3 mb-3',
              novalidate: 'novalidate'
            }
          }) }}
            <div class="row g-2 align-items-end">
              <div class="col-12 col-md-4">
                {{ form_label(searchForm.search_duree) }}
                {{ form_widget(searchForm.search_duree) }}
              </div>
              <div class="col-12 col-md-auto">
                {{ form_widget(searchForm.rechercher) }}
              </div>
              {% if search_duree|default('') is not empty %}
              <div class="col-12 col-md-auto">
                <a href="{{ path('app_credit_search_reset') }}" class="btn btn-outline-secondary w-100">Réinitialiser</a>
              </div>
              {% endif %}
            </div>
          {{ form_end(searchForm) }}

          <div class="card table-responsive ">
            <table class="table mb-0 text-nowrap table-hover">
              <thead class="table-light border-light">
                <tr>
                  <th>Montant</th>
                  <th>Mensualite</th>
                  <th>Duree</th>
                  <th>Statut</th>
                  <th>Date Demande</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                {% for row in creditRows %}
                <tr class="align-middle">
                  <td>{{ row.montant_demande is not null ? row.montant_demande|number_format(2, '.', ' ') ~ ' DT' : '-' }}</td>
                  <td>{{ row.montant_mensuel is not null ? row.montant_mensuel|number_format(2, '.', ' ') ~ ' DT' : '-' }}</td>
                  <td>{{ row.duree_mois is not null ? row.duree_mois ~ ' mois' : '-' }}</td>
                  <td>{{ row.echeance_statut ?? '-' }}</td>
                  <td>{{ row.date_demande is not null ? row.date_demande|date('Y-m-d H:i') : '-' }}</td>
                  <td class="d-flex align-items-center gap-2">
                    {% if isAdmin|default(false) %}
                    {{ form_start(decisionForms[row.id_dossier]['Accept'], {
                      action: path('app_decision_demande', {'id': row.id_dossier}),
                      attr: { class: 'm-0' }
                    }) }}
                      {{ form_widget(decisionForms[row.id_dossier]['Accept'].id_dossier) }}
                      {{ form_widget(decisionForms[row.id_dossier]['Accept'].statut) }}
                      <button type="submit" class="btn btn-sm btn-outline-success" title="Accepter">
                        Accepter
                      </button>
                    {{ form_end(decisionForms[row.id_dossier]['Accept']) }}

                    {{ form_start(decisionForms[row.id_dossier]['Rejet'], {
                      action: path('app_decision_demande', {'id': row.id_dossier}),
                      attr: { class: 'm-0' }
                    }) }}
                      {{ form_widget(decisionForms[row.id_dossier]['Rejet'].id_dossier) }}
                      {{ form_widget(decisionForms[row.id_dossier]['Rejet'].statut) }}
                      <button type="submit" class="btn btn-sm btn-outline-danger" title="Rejeter">
                        Rejeter
                      </button>
                    {{ form_end(decisionForms[row.id_dossier]['Rejet']) }}
                    {% endif %}

                    <a href="{{ path('app_edit_demande_open', {'id': row.id_dossier}) }}" class=""><i class="ti ti-edit "></i></a>
                    {{ form_start(deleteForms[row.id_dossier], {
                      action: path('app_delete_demande', {'id': row.id_dossier}),
                      attr: {
                        class: 'm-0',
                        onsubmit: "return confirm('Confirmer la suppression de cette demande ?');"
                      }
                    }) }}
                      {{ form_widget(deleteForms[row.id_dossier].id) }}
                      <button type="submit" class="btn p-0 border-0 bg-transparent link-danger" aria-label="Supprimer">
                        <i class="ti ti-trash"></i>
                      </button>
                    {{ form_end(deleteForms[row.id_dossier]) }}
                  </td>
                </tr>
                {% else %}
                <tr>
                  <td colspan="6" class="text-center py-4">Vous n'avez pas d'un demande du crédit.</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>


        </div>

      </div>
    <div class="row">
        <div class="col-12">
<footer class="text-center py-2 mt-6 text-white">
  <p class="mb-0 text-white">Copyright © 2026 InApp Credit Dashboard. Developed by <a href="https://codescandy.com/" target="_blank" class="text-white">CodesCandy</a> • Distributed by <a href="https://themewagon.com/" target="_blank" class="text-white">ThemeWagon</a> </p>
      </footer>
        </div>

      </div>




    </div>
  </main>











  <!-- Bootstrap JS -->



</body>

</html>




