{% extends 'admin_layout.html.twig' %}

{% block title %}Account Settings | ESPRIT BANK{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item"><a href="{{ path('app_dashboard') }}">Profile</a></li>
    <li class="breadcrumb-item active" aria-current="page">Settings</li>
{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-xl-8 col-lg-10">
        <div class="card shadow-lg border-0 rounded-4 overflow-hidden mb-4">
            <div class="card-header bg-white py-4 border-0">
                <div class="d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-circle me-3">
                        <i class="fa-solid fa-user-gear text-primary fs-4"></i>
                    </div>
                    <div>
                        <h4 class="fw-bold text-dark mb-0">General Account Settings</h4>
                        <p class="text-muted small mb-0">Manage your personal information and security preferences.</p>
                    </div>
                </div>
            </div>
            
            <div class="card-body p-4 p-md-5">
                {{ form_start(form) }}
                    <div class="row g-4">
                        <div class="col-md-6 text-start">
                            <label class="form-label fw-bold small text-muted text-uppercase">{{ form_label(form.name) }}</label>
                            {{ form_widget(form.name, {'attr': {'class': 'form-control border-0 bg-light p-3 rounded-3'}}) }}
                            {{ form_errors(form.name) }}
                        </div>
                        <div class="col-md-6 text-start">
                            <label class="form-label fw-bold small text-muted text-uppercase">{{ form_label(form.email) }}</label>
                            {{ form_widget(form.email, {'attr': {'class': 'form-control border-0 bg-light p-3 rounded-3'}}) }}
                            {{ form_errors(form.email) }}
                        </div>

                        <div class="col-12 mt-5">
                            <div class="d-flex align-items-center mb-4">
                                <i class="fa-solid fa-shield-halved text-success me-2"></i>
                                <h6 class="fw-bold text-dark mb-0">Security & Authentication</h6>
                            </div>
                            
                            <div class="row g-4">
                                <div class="col-md-6 text-start text-start">
                                    <label class="form-label fw-bold small text-muted text-uppercase">{{ form_label(form.plainPassword.first) }}</label>
                                    {{ form_widget(form.plainPassword.first, {'attr': {'class': 'form-control border-0 bg-light p-3 rounded-3'}}) }}
                                    {{ form_errors(form.plainPassword.first) }}
                                </div>
                                <div class="col-md-6 text-start text-start">
                                    <label class="form-label fw-bold small text-muted text-uppercase">{{ form_label(form.plainPassword.second) }}</label>
                                    {{ form_widget(form.plainPassword.second, {'attr': {'class': 'form-control border-0 bg-light p-3 rounded-3'}}) }}
                                    {{ form_errors(form.plainPassword.second) }}
                                </div>
                            </div>
                        </div>

                        <div class="col-12 mt-5 text-end">
                            <hr class="mb-4 opacity-50">
                            <button type="submit" class="btn btn-primary px-5 py-3 rounded-pill fw-bold shadow-sm">
                                <i class="fa-solid fa-floppy-disk me-2"></i> Save All Changes
                            </button>
                        </div>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>

        <div class="alert alert-warning border-0 shadow-sm rounded-4 p-4 d-flex align-items-start">
            <i class="fa-solid fa-triangle-exclamation fs-4 me-3 mt-1 text-warning"></i>
            <div>
                <h6 class="fw-bold mb-1 text-dark">Data Synchronization Node</h6>
                <p class="mb-0 small text-muted">Updating your Enterprise Email will require a system synchronization check during your next login cycle. Ensure you have access to your secondary recovery methods.</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
