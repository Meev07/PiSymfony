{% extends 'base.html.twig' %}

{% block title %}Sign up | Modern Auth{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/auth.css') }}">
{% endblock %}

{% block body %}
<div class="container d-flex align-items-center justify-content-center min-vh-100 p-3 auth-body">
    <div class="auth-card p-5 w-100">
        <header class="auth-header text-center mb-5">
            <h1 class="h2 mb-2 font-weight-bold">Sign up</h1>
            <p class="text-muted small">Create your Esprit Banking account</p>
        </header>

        {{ form_start(registrationForm) }}
            <div class="form-group mb-4">
                <label for="{{ registrationForm.name.vars.id }}" class="text-muted">Name</label>
                {{ form_widget(registrationForm.name, {'attr': {'class': 'form-control-auth', 'placeholder': 'Your name'}}) }}
                <div class="text-danger small mt-1">{{ form_errors(registrationForm.name) }}</div>
            </div>

            <div class="form-group mb-4">
                <label for="{{ registrationForm.email.vars.id }}" class="text-muted">Email</label>
                {{ form_widget(registrationForm.email, {'attr': {'class': 'form-control-auth', 'placeholder': 'example@email.com'}}) }}
                <div class="text-danger small mt-1">{{ form_errors(registrationForm.email) }}</div>
            </div>

            <div class="form-group mb-4">
                <label for="{{ registrationForm.plainPassword.first.vars.id }}" class="text-muted">Password</label>
                {{ form_widget(registrationForm.plainPassword.first, {'attr': {'class': 'form-control-auth', 'placeholder': 'Create password'}}) }}
                <div class="text-danger small mt-1">{{ form_errors(registrationForm.plainPassword.first) }}</div>
            </div>

            <div class="form-group mb-4">
                <label for="{{ registrationForm.plainPassword.second.vars.id }}" class="text-muted">Confirm Password</label>
                {{ form_widget(registrationForm.plainPassword.second, {'attr': {'class': 'form-control-auth', 'placeholder': 'Repeat password'}}) }}
                <div class="text-danger small mt-1">{{ form_errors(registrationForm.plainPassword.second) }}</div>
            </div>

            <p class="auth-footer-text text-center small mb-4 px-2">
                By sining up, you agreed with our <a href="#" class="auth-link">Terms of Service</a> and <a href="#" class="auth-link">Privacy Policy</a>
            </p>

            <button class="btn btn-auth-submit" type="submit">Sign up</button>
        {{ form_end(registrationForm) }}

        <footer class="text-center mt-5 pt-3">
            <p class="auth-footer-text mb-0">Already have account? <a href="{{ path('app_login') }}" class="auth-link">Log in</a></p>
        </footer>
    </div>
</div>
{% endblock %}
