{% extends 'base.html.twig' %}

{% block title %}Reset password | Modern Auth{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/auth.css') }}">
{% endblock %}

{% block body %}
<div class="container d-flex align-items-center justify-content-center min-vh-100 p-3 auth-body">
    <div class="auth-card p-5 w-100" style="max-width: 450px;">
        <header class="auth-header text-center mb-4">
            <h1 class="h2 mb-2 font-weight-bold">Reset password</h1>
            <p class="text-muted small">Enter your new password below.</p>
        </header>

        {% for message in app.flashes('danger') %}
            <div class="alert alert-danger border-0 rounded-4 p-3 mb-4 shadow-sm small">
                <i class="fa-solid fa-circle-exclamation me-2"></i> {{ message }}
            </div>
        {% endfor %}

        <form method="post">
            <div class="form-group mb-4">
                <label for="inputPassword" class="text-muted">New Password</label>
                <input type="password" name="password" id="inputPassword" class="form-control-auth" required autofocus placeholder="New password">
            </div>

            <div class="form-group mb-5">
                <label for="inputConfirmPassword" class="text-muted">Confirm New Password</label>
                <input type="password" name="confirm_password" id="inputConfirmPassword" class="form-control-auth" required placeholder="Repeat new password">
            </div>

            <button class="btn btn-auth-submit" type="submit">Update Password</button>
        </form>

        <footer class="text-center mt-5 pt-3">
            <p class="auth-footer-text mb-0">Back to <a href="{{ path('app_login') }}" class="auth-link">Log in</a></p>
        </footer>
    </div>
</div>
{% endblock %}
