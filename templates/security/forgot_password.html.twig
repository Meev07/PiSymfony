{% extends 'base.html.twig' %}

{% block title %}Forgot password | Modern Auth{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/auth.css') }}">
{% endblock %}

{% block body %}
<div class="container d-flex align-items-center justify-content-center min-vh-100 p-3 auth-body">
    <div class="auth-card p-5 w-100">
        <header class="auth-header text-center mb-4">
            <h1 class="h2 mb-2 font-weight-bold">Forgot password</h1>
            <p class="text-muted small">
                Enter your email address and we'll send you a link to reset your password.
            </p>
        </header>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success border-0 rounded-4 p-3 mb-4 shadow-sm small">
                <i class="fa-solid fa-circle-check me-2"></i> {{ message }}
            </div>
        {% endfor %}

        <form method="post">
            <div class="form-group mb-5">
                <label for="inputEmail" class="text-muted">Email</label>
                <input type="email" name="email" id="inputEmail" class="form-control-auth" required autofocus placeholder="Email">
            </div>

            <button class="btn btn-auth-submit" type="submit">Send</button>
        </form>

        <footer class="text-center mt-5 pt-3">
            <p class="auth-footer-text mb-0">Already have account? <a href="{{ path('app_login') }}" class="auth-link">Log in</a></p>
        </footer>
    </div>
</div>
{% endblock %}
